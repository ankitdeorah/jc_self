        "from __future__ import annotations\n",
        "\"\"\"Single-file canonical EdTech synthetic data pipeline.\n",
        "\n",
        "This module generates all final dataset tables, validates relational and temporal\n",
        "consistency, and exports both CSV and Excel artifacts.\n",
        "\"\"\"\n",
        "\n",
        "import argparse\n",
        "import json\n",
        "import re\n",
        "import sys\n",
        "import uuid\n",
        "from dataclasses import asdict, dataclass\n",
        "from datetime import date, datetime, timedelta\n",
        "from pathlib import Path\n",
        "from typing import Dict, List, Optional, Tuple\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "# Expand terminal display for validation\n",
        "pd.set_option('display.max_columns', None)\n",
        "pd.set_option('display.width', 1000)\n",
        "\n",
        "# Runtime and data-shape controls for reproducible generation.\n",
        "@dataclass(frozen=True)\n",
        "class PipelineConfig:\n",
        "    output_dir: str = \"IIMA_EDtech_Canonical\"\n",
        "    excel_filename: str = \"IIMA_EDtech_Full_Dataset_Canonical.xlsx\"\n",
        "    seed: int = 20260420\n",
        "    enrollment_year: int = 2025\n",
        "    num_students_target: int = 5100\n",
        "    num_teachers: int = 50\n",
        "    churn_ratio: float = 0.10\n",
        "    standalone_max_students: int = 450\n",
        "    history_months: int = 18\n",
        "    legacy_finance_ratio: float = 0.08\n",
        "    session_weeks: int = 27\n",
        "    assignment_count: int = 6\n",
        "    min_legacy_finance_students: int = 120\n",
        "    as_of_date: Optional[str] = None\n",
        "\n",
        "# Source vocabularies and program catalog used across table generators.\n",
        "FIRST_NAMES = [\n",
        "    \"Aarav\", \"Ananya\", \"Vihaan\", \"Diya\", \"Aditya\", \"Zoya\", \"Ishaan\", \"Kiara\", \"Arjun\", \"Prisha\",\n",
        "    \"Rohan\", \"Meera\", \"Siddharth\", \"Sia\", \"Dev\", \"Tanvi\", \"Sahil\", \"Isha\", \"Yash\", \"Alisha\",\n",
        "]\n",
        "\n",
        "LAST_NAMES = [\n",
        "    \"Sharma\", \"Verma\", \"Gupta\", \"Malhotra\", \"Patel\", \"Reddy\", \"Nair\", \"Iyer\", \"Singh\", \"Joshi\",\n",
        "]\n",
        "\n",
        "SUBJECTS = [\"Physics\", \"Chemistry\", \"Maths\", \"Biology\"]\n",
        "\n",
        "TOPIC_BANK = [\n",
        "    \"Physics: Kinematics\", \"Physics: Newtonian Mechanics\", \"Physics: Work and Energy\",\n",
        "    \"Physics: Waves and Sound\", \"Physics: Electrostatics\", \"Physics: Current Electricity\",\n",
        "    \"Physics: Magnetism\", \"Physics: Ray Optics\", \"Chemistry: Atomic Structure\",\n",
        "    \"Chemistry: Chemical Bonding\", \"Chemistry: Thermodynamics\", \"Chemistry: Equilibrium\",\n",
        "    \"Chemistry: Organic Nomenclature\", \"Chemistry: Hydrocarbons\", \"Chemistry: Biomolecules\",\n",
        "    \"Biology: Cell Structure\", \"Biology: Biomolecules\", \"Biology: Genetics\",\n",
        "    \"Biology: Human Physiology\", \"Biology: Plant Physiology\", \"Biology: Ecology\",\n",
        "    \"Maths: Algebra\", \"Maths: Trigonometry\", \"Maths: Coordinate Geometry\",\n",
        "    \"Maths: Differential Calculus\", \"Maths: Integral Calculus\", \"Maths: Probability\",\n",
        "    \"Maths: Permutation and Combination\",\n",
        "]\n",
        "\n",
        "PROGRAM_CONFIGS = [\n",
        "    {\"name\": \"NEET/JEE Stand-Alone Grade 9\", \"fee\": 125000, \"path\": \"SA-9\", \"grade\": 9},\n",
        "    {\"name\": \"NEET/JEE Stand-Alone Grade 10\", \"fee\": 135000, \"path\": \"SA-10\", \"grade\": 10},\n",
        "    {\"name\": \"NEET/JEE Stand-Alone Grade 11\", \"fee\": 155000, \"path\": \"SA-11\", \"grade\": 11},\n",
        "    {\"name\": \"NEET/JEE Stand-Alone Grade 12\", \"fee\": 175000, \"path\": \"SA-12\", \"grade\": 12},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 9 (9-12 Path)\", \"fee\": 80000, \"path\": \"INT-9-12\", \"grade\": 9},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 10 (9-12 Path)\", \"fee\": 95000, \"path\": \"INT-9-12\", \"grade\": 10},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 11 (9-12 Path)\", \"fee\": 120000, \"path\": \"INT-9-12\", \"grade\": 11},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 12 (9-12 Path)\", \"fee\": 130000, \"path\": \"INT-9-12\", \"grade\": 12},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 10 (10-12 Path)\", \"fee\": 110000, \"path\": \"INT-10-12\", \"grade\": 10},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 11 (10-12 Path)\", \"fee\": 135000, \"path\": \"INT-10-12\", \"grade\": 11},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 12 (10-12 Path)\", \"fee\": 145000, \"path\": \"INT-10-12\", \"grade\": 12},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 11 (11-12 Path)\", \"fee\": 150000, \"path\": \"INT-11-12\", \"grade\": 11},\n",
        "    {\"name\": \"NEET/JEE Integrated Grade 12 (11-12 Path)\", \"fee\": 160000, \"path\": \"INT-11-12\", \"grade\": 12}\n",
        "]\n",
        "\n",
        "def _stable_id(seed: int, entity: str, idx: int) -> str:\n",
        "    return str(uuid.uuid5(uuid.NAMESPACE_URL, f\"{seed}:{entity}:{idx}\"))\n",
        "\n",
        "def _name_pool(rng: np.random.Generator, count: int) -> List[str]:\n",
        "    combos = [f\"{f} {l}\" for f in FIRST_NAMES for l in LAST_NAMES]\n",
        "    if count > len(combos):\n",
        "        raise ValueError(\"Name pool is too small for requested unique names\")\n",
        "    picks = rng.choice(len(combos), size=count, replace=False)\n",
        "    return [combos[int(i)] for i in picks]\n",
        "\n",
        "def _email_from_name(name: str, domain: str = \"academy.com\") -> str:\n",
        "    clean = re.sub(r\"[^A-Za-z]\", \"\", name)\n",
        "    slug = re.sub(r\"\\s+\", \".\", clean.strip().lower())\n",
        "    slug = re.sub(r\"\\.+\", \".\", slug).strip(\".\")\n",
        "    return f\"{slug}@{domain}\"\n",
        "\n",
        "def _path_meta(path: str, grade: int) -> Tuple[int, int, int, int, bool]:\n",
        "    if path.startswith(\"SA\"):\n",
        "        return grade, grade, 1, 1, False\n",
        "    parts = path.split(\"-\")\n",
        "    start_grade = int(parts[1])\n",
        "    end_grade = int(parts[2])\n",
        "    program_year = grade - start_grade + 1\n",
        "    duration = end_grade - start_grade + 1\n",
        "    return start_grade, end_grade, duration, program_year, True\n",
        "\n",
        "def _split_amount(total: int, parts: int) -> List[int]:\n",
        "    base = total // parts\n",
        "    remainder = total % (base * parts) if base > 0 else total\n",
        "    return [base + (1 if i < remainder else 0) for i in range(parts)]\n",
        "\n",
        "def _effective_history_months(cfg: PipelineConfig) -> int:\n",
        "    return int(min(24, max(12, cfg.history_months)))\n",
        "\n",
        "def _dataset_window(cfg: PipelineConfig) -> Tuple[date, date]:\n",
        "    \"\"\"Return the bounded generation window based on config and optional as-of date.\"\"\"\n",
        "    start_date = date(cfg.enrollment_year, 6, 15)\n",
        "    requested_end = start_date + timedelta(days=(_effective_history_months(cfg) * 30)-1)\n",
        "    if cfg.as_of_date:\n",
        "        try:\n",
        "            as_of = datetime.strptime(cfg.as_of_date, \"%Y-%m-%d\").date()\n",
        "        except ValueError as exc:\n",
        "            raise ValueError(\"as_of_date must be in YYYY-MM-DD format\") from exc\n",
        "    else:\n",
        "        as_of = datetime.now().date()\n",
        "    end_date = min(as_of, requested_end)\n",
        "    if end_date < start_date:\n",
        "        end_date = start_date\n",
        "    return start_date, end_date\n",
        "\n",
        "def _history_days(cfg: PipelineConfig) -> int:\n",
        "    start, end = _dataset_window(cfg)\n",
        "    return int(max(1, (end - start).days + 1))\n",
        "\n",
        "def _months_available(cfg: PipelineConfig) -> int:\n",
        "    start, end = _dataset_window(cfg)\n",
        "    return int(max(1, ((end.year - start.year) * 12 + (end.month - start.month) + 1)))\n",
        "\n",
        "def _program_table(cfg: PipelineConfig, run_date: date) -> pd.DataFrame:\n",
        "    rows: List[dict] = []\n",
        "    start_date, _ = _dataset_window(cfg)\n",
        "    for i, p in enumerate(PROGRAM_CONFIGS):\n",
        "        start_grade, end_grade, duration, program_year, is_integrated = _path_meta(p[\"path\"], p[\"grade\"])\n",
        "        rows.append({\n",
        "            \"program_id\": _stable_id(cfg.seed, \"program\", i),\n",
        "            \"name\": p[\"name\"],\n",
        "            \"path\": p[\"path\"],\n",
        "            \"grade\": int(p[\"grade\"]),\n",
        "            \"batch_start_date\": start_date,\n",
        "            \"annual_fee\": int(p[\"fee\"]),\n",
        "            \"path_start_grade\": int(start_grade),\n",
        "            \"path_end_grade\": int(end_grade),\n",
        "            \"program_duration\": int(duration),\n",
        "            \"program_year\": int(program_year),\n",
        "            \"is_integrated\": bool(is_integrated),\n",
        "            \"created_at\": run_date,\n",
        "            \"updated_at\": run_date,\n",
        "        })\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _faculty_table(cfg: PipelineConfig, rng: np.random.Generator, run_date: date) -> pd.DataFrame:\n",
        "    total_people = 1 + 4 + 4 + 5 + max(50, cfg.num_teachers)\n",
        "    names = _name_pool(rng, total_people)\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "\n",
        "    dean_name = f\"Dr. {names[idx]}\"\n",
        "    rows.append({\n",
        "        \"faculty_id\": _stable_id(cfg.seed, \"faculty\", idx),\n",
        "        \"name\": dean_name,\n",
        "        \"role\": \"Dean\",\n",
        "        \"role_group\": \"Leadership\",\n",
        "        \"expertise\": \"Academic Strategy\",\n",
        "        \"teaches_grades\": \"\",\n",
        "        \"hierarchy_level\": 1,\n",
        "        \"email\": _email_from_name(dean_name),\n",
        "        \"created_at\": run_date,\n",
        "    })\n",
        "    idx += 1\n",
        "\n",
        "    for subject in SUBJECTS:\n",
        "        hod_name = f\"Dr. {names[idx]}\"\n",
        "        rows.append({\n",
        "            \"faculty_id\": _stable_id(cfg.seed, \"faculty\", idx),\n",
        "            \"name\": hod_name,\n",
        "            \"role\": \"HOD\",\n",
        "            \"role_group\": \"Leadership\",\n",
        "            \"expertise\": subject,\n",
        "            \"teaches_grades\": \"\",\n",
        "            \"hierarchy_level\": 2,\n",
        "            \"email\": _email_from_name(hod_name),\n",
        "            \"created_at\": run_date,\n",
        "        })\n",
        "        idx += 1\n",
        "\n",
        "    counselor_domains = [\"Mental Wellness\", \"Professional Development\", \"Behavioral Science\", \"Career Guidance\"]\n",
        "    for domain in counselor_domains:\n",
        "        name = names[idx]\n",
        "        rows.append({\n",
        "            \"faculty_id\": _stable_id(cfg.seed, \"faculty\", idx),\n",
        "            \"name\": name,\n",
        "            \"role\": \"Student Counselor\",\n",
        "            \"role_group\": \"Student Success\",\n",
        "            \"expertise\": domain,\n",
        "            \"teaches_grades\": \"\",\n",
        "            \"hierarchy_level\": 3,\n",
        "            \"email\": _email_from_name(name),\n",
        "            \"created_at\": run_date,\n",
        "        })\n",
        "        idx += 1\n",
        "\n",
        "    for coordinator_no in range(1, 6):\n",
        "        name = names[idx]\n",
        "        rows.append({\n",
        "            \"faculty_id\": _stable_id(cfg.seed, \"faculty\", idx),\n",
        "            \"name\": name,\n",
        "            \"role\": \"Course Coordinator\",\n",
        "            \"role_group\": \"Administration\",\n",
        "            \"expertise\": f\"Cohort Operations {coordinator_no}\",\n",
        "            \"teaches_grades\": \"\",\n",
        "            \"hierarchy_level\": 3,\n",
        "            \"email\": _email_from_name(name),\n",
        "            \"created_at\": run_date,\n",
        "        })\n",
        "        idx += 1\n",
        "\n",
        "    teacher_count = max(50, cfg.num_teachers)\n",
        "    senior_count = max(18, int(round(teacher_count * 0.44)))\n",
        "    junior_count = teacher_count - senior_count\n",
        "    doctorate_senior_count = min(6, max(3, senior_count // 4))\n",
        "\n",
        "    for teacher_idx in range(senior_count):\n",
        "        base_name = names[idx]\n",
        "        name = f\"Dr. {base_name}\" if teacher_idx < doctorate_senior_count else base_name\n",
        "        rows.append({\n",
        "            \"faculty_id\": _stable_id(cfg.seed, \"faculty\", idx),\n",
        "            \"name\": name,\n",
        "            \"role\": \"Senior Faculty\",\n",
        "            \"role_group\": \"Teaching\",\n",
        "            \"expertise\": str(rng.choice(SUBJECTS)),\n",
        "            \"teaches_grades\": \"11,12\",\n",
        "            \"hierarchy_level\": 4,\n",
        "            \"email\": _email_from_name(name),\n",
        "            \"created_at\": run_date,\n",
        "        })\n",
        "        idx += 1\n",
        "\n",
        "    for _ in range(junior_count):\n",
        "        name = names[idx]\n",
        "        rows.append({\n",
        "            \"faculty_id\": _stable_id(cfg.seed, \"faculty\", idx),\n",
        "            \"name\": name,\n",
        "            \"role\": \"Junior Faculty\",\n",
        "            \"role_group\": \"Teaching\",\n",
        "            \"expertise\": str(rng.choice(SUBJECTS)),\n",
        "            \"teaches_grades\": \"9,10\",\n",
        "            \"hierarchy_level\": 4,\n",
        "            \"email\": _email_from_name(name),\n",
        "            \"created_at\": run_date,\n",
        "        })\n",
        "        idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def integrated_profile_counts(intake: int, retentions: List[float], min_count: int) -> List[int]:\n",
        "    counts = [int(intake)]\n",
        "    current = float(intake)\n",
        "    for retention in retentions:\n",
        "        current = max(float(min_count), round(current * retention))\n",
        "        counts.append(int(current))\n",
        "    return counts\n",
        "\n",
        "def cohort_table(cfg: PipelineConfig, rng: np.random.Generator, df_program: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Allocate student counts per cohort with caps and integrated-path retention shape.\"\"\"\n",
        "    cap = int(cfg.standalone_max_students)\n",
        "    minimum_target = max(5001, cfg.num_students_target)\n",
        "    desired_total = min(cap * len(df_program), minimum_target + int(rng.integers(30, 151)))\n",
        "\n",
        "    standalone = df_program[df_program[\"path\"].str.startswith(\"SA\")].copy()\n",
        "    integrated = df_program[df_program[\"path\"].str.startswith(\"INT\")].copy()\n",
        "    standalone_counts: Dict[str, int] = {}\n",
        "\n",
        "    for _, program in standalone.iterrows():\n",
        "        standalone_counts[str(program[\"program_id\"])] = int(rng.integers(340, min(cap, 430) + 1))\n",
        "\n",
        "    integrated_profiles: Dict[str, dict] = {}\n",
        "    for path, grp in integrated.groupby(\"path\"):\n",
        "        ordered = grp.sort_values(\"grade\")\n",
        "        duration = int(len(ordered))\n",
        "        if duration == 4:\n",
        "            intake_low, intake_high = 405, min(cap, 440)\n",
        "            retention_low, retention_high = 0.92, 0.97\n",
        "        elif duration == 3:\n",
        "            intake_low, intake_high = 400, min(cap, 438)\n",
        "            retention_low, retention_high = 0.915, 0.968\n",
        "        else:\n",
        "            intake_low, intake_high = 395, min(cap, 435)\n",
        "            retention_low, retention_high = 0.91, 0.965\n",
        "\n",
        "        integrated_profiles[path] = {\n",
        "            \"program_ids\": list(ordered[\"program_id\"]),\n",
        "            \"intake\": int(rng.integers(intake_low, intake_high + 1)),\n",
        "            \"retentions\": [float(rng.uniform(retention_low, retention_high)) for _ in range(duration - 1)],\n",
        "            \"min_count\": 220,\n",
        "        }\n",
        "\n",
        "    def build_counts() -> Tuple[int, Dict[str, int]]:\n",
        "        counts: Dict[str, int] = {}\n",
        "        for pid, count in standalone_counts.items():\n",
        "            counts[pid] = min(cap, int(count))\n",
        "        for profile in integrated_profiles.values():\n",
        "            path_counts = integrated_profile_counts(profile[\"intake\"], profile[\"retentions\"], profile[\"min_count\"])\n",
        "            for i, pid in enumerate(profile[\"program_ids\"]):\n",
        "                counts[str(pid)] = min(cap, int(path_counts[i]))\n",
        "        return int(sum(counts.values())), counts\n",
        "\n",
        "    total_students, all_counts = build_counts()\n",
        "    iterations = 0\n",
        "    path_keys = sorted(integrated_profiles.keys())\n",
        "\n",
        "    while total_students < desired_total and iterations < 5000:\n",
        "        boost_standalone = bool(rng.random() < 0.35)\n",
        "        if boost_standalone:\n",
        "            eligible_sa = [pid for pid, value in standalone_counts.items() if value < cap]\n",
        "            if eligible_sa:\n",
        "                chosen = str(rng.choice(eligible_sa))\n",
        "                standalone_counts[chosen] += 1\n",
        "            else:\n",
        "                boost_standalone = False\n",
        "        if not boost_standalone:\n",
        "            eligible_paths = [path for path in path_keys if integrated_profiles[path][\"intake\"] < cap]\n",
        "            if eligible_paths:\n",
        "                chosen_path = str(rng.choice(eligible_paths))\n",
        "                integrated_profiles[chosen_path][\"intake\"] += 1\n",
        "            else:\n",
        "                for path in path_keys:\n",
        "                    rets = integrated_profiles[path][\"retentions\"]\n",
        "                    for r_idx in range(len(rets)):\n",
        "                        rets[r_idx] = min(0.985, rets[r_idx] + 0.0005)\n",
        "        total_students, all_counts = build_counts()\n",
        "        iterations += 1\n",
        "\n",
        "    if total_students < minimum_target:\n",
        "        raise ValueError(\"Unable to satisfy student target while honoring cohort caps\")\n",
        "\n",
        "    rows: List[dict] = []\n",
        "    for i, (_, program) in enumerate(df_program.iterrows()):\n",
        "        pid = str(program[\"program_id\"])\n",
        "        rows.append({\n",
        "            \"cohort_id\": _stable_id(cfg.seed, \"cohort\", i),\n",
        "            \"program_id\": program[\"program_id\"],\n",
        "            \"path\": program[\"path\"],\n",
        "            \"grade\": int(program[\"grade\"]),\n",
        "            \"program_year\": int(program[\"program_year\"]),\n",
        "            \"program_duration\": int(program[\"program_duration\"]),\n",
        "            \"total_students\": int(all_counts[pid]),\n",
        "            \"start_date\": program[\"batch_start_date\"],\n",
        "        })\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def student_table(cfg: PipelineConfig, rng: np.random.Generator, df_cohort: pd.DataFrame) -> pd.DataFrame:\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, cohort in df_cohort.iterrows():\n",
        "        path = str(cohort[\"path\"])\n",
        "        grade = int(cohort[\"grade\"])\n",
        "        program_year = int(cohort[\"program_year\"])\n",
        "        program_duration = int(cohort[\"program_duration\"])\n",
        "        join_year = int(cfg.enrollment_year - (program_year - 1))\n",
        "        path_code = path.lower().replace(\"-\", \"\")\n",
        "\n",
        "        for i in range(int(cohort[\"total_students\"])):\n",
        "            first = str(rng.choice(FIRST_NAMES))\n",
        "            last = str(rng.choice(LAST_NAMES))\n",
        "            churn_prob = cfg.churn_ratio + (0.03 * (program_year - 1) if path.startswith(\"INT\") else 0.01 * (grade - 9))\n",
        "            churn_prob = min(0.35, max(0.05, churn_prob))\n",
        "            status = \"inactive\" if rng.random() < churn_prob else \"active\"\n",
        "\n",
        "            rows.append({\n",
        "                \"student_id\": _stable_id(cfg.seed, \"student\", idx),\n",
        "                \"name\": f\"{first} {last}\",\n",
        "                \"email\": f\"{first.lower()}.{last.lower()}.{i}.{path_code}.jy{join_year}@student.academy.com\",\n",
        "                \"program_id\": cohort[\"program_id\"],\n",
        "                \"program_year\": program_year,\n",
        "                \"program_duration\": program_duration,\n",
        "                \"join_year\": join_year,\n",
        "                \"cohort_id\": cohort[\"cohort_id\"],\n",
        "                \"path\": path,\n",
        "                \"grade\": grade,\n",
        "                \"status\": status,\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _session_table(cfg: PipelineConfig, rng: np.random.Generator, df_cohort: pd.DataFrame) -> pd.DataFrame:\n",
        "    start_date, end_date = _dataset_window(cfg)\n",
        "    history_weeks = int(np.ceil(_history_days(cfg) / 7))\n",
        "    total_weeks = max(1, max(cfg.session_weeks, history_weeks))\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "\n",
        "    for _, cohort in df_cohort.iterrows():\n",
        "        for week in range(total_weeks):\n",
        "            session_date = cohort[\"start_date\"] + timedelta(days=week * 7)\n",
        "            if session_date > end_date:\n",
        "                break\n",
        "            rows.append({\n",
        "                \"session_id\": _stable_id(cfg.seed, \"session\", idx),\n",
        "                \"cohort_id\": cohort[\"cohort_id\"],\n",
        "                \"session_number\": week + 1,\n",
        "                \"topic\": str(rng.choice(TOPIC_BANK)),\n",
        "                \"session_date\": session_date,\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _attendance_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_session: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    session_lists = (\n",
        "        df_session.sort_values([\"cohort_id\", \"session_date\"])\n",
        "        .groupby(\"cohort_id\", sort=False)\n",
        "        .agg({\"session_id\": list, \"session_date\": list})\n",
        "    )\n",
        "    sessions_by_cohort = {\n",
        "        cohort_id: list(zip(row[\"session_id\"], row[\"session_date\"]))\n",
        "        for cohort_id, row in session_lists.iterrows()\n",
        "    }\n",
        "\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, student in df_student.iterrows():\n",
        "        is_churned = student[\"status\"] == \"inactive\"\n",
        "        is_integrated = str(student[\"path\"]).startswith(\"INT\")\n",
        "        p_attended = 0.25 if is_churned else (0.90 if is_integrated else 0.84)\n",
        "\n",
        "        for session_id, session_date in sessions_by_cohort[student[\"cohort_id\"]]:\n",
        "            attended = bool(rng.random() < p_attended)\n",
        "            if not attended:\n",
        "                engagement = 0\n",
        "            elif is_churned:\n",
        "                engagement = int(rng.integers(12, 52))\n",
        "            elif is_integrated:\n",
        "                engagement = int(rng.integers(68, 100))\n",
        "            else:\n",
        "                engagement = int(rng.integers(60, 96))\n",
        "\n",
        "            rows.append({\n",
        "                \"attendance_id\": _stable_id(cfg.seed, \"attendance\", idx),\n",
        "                \"student_id\": student[\"student_id\"],\n",
        "                \"session_id\": session_id,\n",
        "                \"session_date\": session_date,\n",
        "                \"attendance_month\": pd.Timestamp(session_date).to_period(\"M\").strftime(\"%Y-%m\"),\n",
        "                \"attended\": attended,\n",
        "                \"engagement_score\": engagement,\n",
        "                \"created_at\": run_date,\n",
        "                \"updated_at\": run_date,\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _assignment_table(cfg: PipelineConfig, df_cohort: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    assignment_kinds = [\n",
        "        \"Monthly Quiz\", \"Practice Test\", \"Concept Drill\", \"Revision Worksheet\",\n",
        "        \"Timed Assessment\", \"Application Problem Set\"\n",
        "    ]\n",
        "    _, end_date = _dataset_window(cfg)\n",
        "    total_assignments = max(1, min(max(cfg.assignment_count, _effective_history_months(cfg)), _months_available(cfg)))\n",
        "\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, cohort in df_cohort.iterrows():\n",
        "        for month_idx in range(total_assignments):\n",
        "            kind = assignment_kinds[month_idx % len(assignment_kinds)]\n",
        "            due_date = cohort[\"start_date\"] + timedelta(days=(month_idx + 1) * 30)\n",
        "            if due_date > end_date:\n",
        "                break\n",
        "            rows.append({\n",
        "                \"assignment_id\": _stable_id(cfg.seed, \"assignment\", idx),\n",
        "                \"cohort_id\": cohort[\"cohort_id\"],\n",
        "                \"title\": f\"{kind} {month_idx + 1}\",\n",
        "                \"max_points\": 100,\n",
        "                \"due_date\": due_date,\n",
        "                \"weightage\": round(1 / total_assignments, 3),\n",
        "                \"created_at\": run_date,\n",
        "                \"updated_at\": run_date,\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _submission_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_assignment: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    students_by_cohort = {cohort_id: group.to_dict(\"records\") for cohort_id, group in df_student.groupby(\"cohort_id\")}\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, assignment in df_assignment.iterrows():\n",
        "        for student in students_by_cohort[assignment[\"cohort_id\"]]:\n",
        "            is_churned = student[\"status\"] == \"inactive\"\n",
        "            is_integrated = str(student[\"path\"]).startswith(\"INT\")\n",
        "            submit_prob = 0.42 if is_churned else (0.96 if is_integrated else 0.92)\n",
        "\n",
        "            if rng.random() >= submit_prob:\n",
        "                continue\n",
        "\n",
        "            if is_churned:\n",
        "                score = int(rng.integers(20, 61))\n",
        "            elif is_integrated:\n",
        "                score = int(rng.integers(72, 101))\n",
        "            else:\n",
        "                score = int(rng.integers(65, 99))\n",
        "\n",
        "            rows.append({\n",
        "                \"submission_id\": _stable_id(cfg.seed, \"submission\", idx),\n",
        "                \"assignment_id\": assignment[\"assignment_id\"],\n",
        "                \"student_id\": student[\"student_id\"],\n",
        "                \"submission_date\": assignment[\"due_date\"] - timedelta(days=int(rng.integers(0, 7))),\n",
        "                \"score\": score,\n",
        "                \"status\": \"graded\",\n",
        "                \"created_at\": run_date,\n",
        "                \"updated_at\": run_date,\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _student_metrics_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_attendance: pd.DataFrame, df_submission: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    score_by_student = df_submission.groupby(\"student_id\")[\"score\"].mean()\n",
        "    attendance_pct = df_attendance.groupby(\"student_id\")[\"attended\"].mean() * 100\n",
        "    engagement_avg = df_attendance.groupby(\"student_id\")[\"engagement_score\"].mean()\n",
        "\n",
        "    rows: List[dict] = []\n",
        "    for idx, (_, student) in enumerate(df_student.iterrows()):\n",
        "        is_churned = student[\"status\"] == \"inactive\"\n",
        "        idle_days = int(rng.integers(40, 181) if is_churned else rng.integers(0, 60))\n",
        "        avg_score = float(score_by_student.get(student[\"student_id\"], np.nan))\n",
        "        if np.isnan(avg_score):\n",
        "            avg_score = 35.0 if is_churned else 74.0\n",
        "\n",
        "        attendance = float(attendance_pct.get(student[\"student_id\"], np.nan))\n",
        "        if np.isnan(attendance):\n",
        "            attendance = 22.0 if is_churned else 78.0\n",
        "\n",
        "        engagement = float(engagement_avg.get(student[\"student_id\"], np.nan))\n",
        "        if np.isnan(engagement):\n",
        "            engagement = 28.0 if is_churned else 76.0\n",
        "\n",
        "        rows.append({\n",
        "            \"student_id\": student[\"student_id\"],\n",
        "            \"metric_id\": _stable_id(cfg.seed, \"student_metric\", idx),\n",
        "            \"avg_assignment_score\": round(avg_score, 2),\n",
        "            \"attendance_percentage\": round(attendance, 2),\n",
        "            \"avg_engagement_score\": round(engagement, 2),\n",
        "            \"last_login_date\": run_date - timedelta(days=idle_days),\n",
        "            \"updated_at\": run_date,\n",
        "        })\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def churn_prediction_table(cfg: PipelineConfig, df_student_metrics: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    rows: List[dict] = []\n",
        "    for idx, (_, metric) in enumerate(df_student_metrics.iterrows()):\n",
        "        att = float(metric[\"attendance_percentage\"])\n",
        "        score = float(metric[\"avg_assignment_score\"])\n",
        "        engagement = float(metric[\"avg_engagement_score\"])\n",
        "        recency = float((run_date - metric[\"last_login_date\"]).days)\n",
        "\n",
        "        logit = -1.2 + (52 - att) * 0.055 + (60 - score) * 0.035 + (56 - engagement) * 0.03 + recency * 0.01\n",
        "        probability = float(1/(1 + np.exp(-logit)))\n",
        "        probability = max(0.01, min(0.99, probability))\n",
        "\n",
        "        if probability > 0.70:\n",
        "            risk = \"high\"\n",
        "        elif probability > 0.35:\n",
        "            risk = \"medium\"\n",
        "        else:\n",
        "            risk = \"low\"\n",
        "\n",
        "        rows.append({\n",
        "            \"prediction_id\": _stable_id(cfg.seed, \"churn_prediction\", idx),\n",
        "            \"student_id\": metric[\"student_id\"],\n",
        "            \"churn_probability\": round(probability, 4),\n",
        "            \"risk_level\": risk,\n",
        "            \"predicted_at\": run_date,\n",
        "        })\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def feedback_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    comments = [\n",
        "        \"Very helpful\", \"Good pace\", \"Too difficult\", \"Content too fast\",\n",
        "        \"Excellent support\", \"Counseling support is useful\", \"Need more practice tests\"\n",
        "    ]\n",
        "    sample = df_student.sample(frac=0.32, random_state=cfg.seed)\n",
        "    rows: List[dict] = []\n",
        "    for idx, (_, student) in enumerate(sample.iterrows()):\n",
        "        is_churned = student[\"status\"] == \"inactive\"\n",
        "        rows.append({\n",
        "            \"feedback_id\": _stable_id(cfg.seed, \"feedback\", idx),\n",
        "            \"student_id\": student[\"student_id\"],\n",
        "            \"rating\": int(rng.integers(1, 4) if is_churned else rng.integers(3, 6)),\n",
        "            \"comments\": str(rng.choice(comments)),\n",
        "            \"created_at\": run_date,\n",
        "        })\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _fee_schedules(df_program: pd.DataFrame) -> Dict[str, List[Tuple[int, int]]]:\n",
        "    schedules: Dict[str, List[Tuple[int, int]]] = {}\n",
        "    for path, group in df_program.groupby(\"path\"):\n",
        "        ordered = group.sort_values(\"grade\")\n",
        "        schedules[path] = [(int(r[\"grade\"]), int(r[\"annual_fee\"])) for _, r in ordered.iterrows()]\n",
        "    return schedules\n",
        "\n",
        "def payment_and_finance_tables(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_program: pd.DataFrame, run_date: date) -> Tuple[pd.DataFrame, pd.DataFrame]:\n",
        "    fee_schedule = _fee_schedules(df_program)\n",
        "    payment_rows: List[dict] = []\n",
        "    finance_rows: List[dict] = []\n",
        "    payment_idx = 0\n",
        "\n",
        "    def add_financial_record(student_id: str, path: str, grade: int, program_year: int, program_duration: int, join_year: int, student_status: str, is_legacy: bool) -> None:\n",
        "        nonlocal payment_idx\n",
        "        schedule = fee_schedule[path]\n",
        "        year_fees = [fee[1] for fee in schedule]\n",
        "        current_year_fee = int(year_fees[program_year - 1])\n",
        "        cumulative_to_year = int(sum(year_fees[:program_year]))\n",
        "        full_program_fee = int(sum(year_fees))\n",
        "        paid_total = 0\n",
        "\n",
        "        for prior_year in range(program_year - 1):\n",
        "            prior_fee = int(year_fees[prior_year])\n",
        "            academic_year = int(join_year + prior_year)\n",
        "            pay_date = date(academic_year, 6, 15) + timedelta(days=int(rng.integers(10,45)))\n",
        "            payment_rows.append({\n",
        "                \"payment_id\": _stable_id(cfg.seed, \"payment\", payment_idx),\n",
        "                \"student_id\": student_id,\n",
        "                \"is_legacy_student\": is_legacy,\n",
        "                \"path\": path,\n",
        "                \"program_year\": prior_year + 1,\n",
        "                \"academic_year\": academic_year,\n",
        "                \"installment_no\": 1,\n",
        "                \"installment_count\": 1,\n",
        "                \"amount\": prior_fee,\n",
        "                \"payment_plan\": \"annual\",\n",
        "                \"payment_date\": pay_date,\n",
        "                \"payment_method\": str(rng.choice([\"upi\", \"card\", \"net banking\"])),\n",
        "                \"status\": \"paid\",\n",
        "                \"created_at\": run_date,\n",
        "            })\n",
        "            payment_idx += 1\n",
        "            paid_total += prior_fee\n",
        "\n",
        "        payment_plan = str(rng.choice([\"quarterly\", \"half_yearly\", \"annual\"], p=[0.45, 0.35, 0.20]))\n",
        "        installment_count = {\"quarterly\": 4, \"half_yearly\": 2, \"annual\": 1}[payment_plan]\n",
        "        installment_amounts = _split_amount(current_year_fee, installment_count)\n",
        "\n",
        "        if is_legacy:\n",
        "            max_paid = max(1, installment_count - 1)\n",
        "            paid_installments = int(rng.integers(1, max_paid + 1))\n",
        "        elif student_status == \"inactive\":\n",
        "            paid_installments = int(rng.integers(1, installment_count + 1))\n",
        "        else:\n",
        "            min_paid = 1 if installment_count == 1 else int(np.ceil(installment_count / 2))\n",
        "            paid_installments = int(rng.integers(min_paid, installment_count + 1))\n",
        "\n",
        "        spacing_days = {\"quarterly\": 90, \"half_yearly\": 180, \"annual\": 0}[payment_plan]\n",
        "        current_year = int(cfg.enrollment_year)\n",
        "        current_year_start = date(current_year, 6, 15)\n",
        "\n",
        "        for i, amount in enumerate(installment_amounts):\n",
        "            status = \"paid\" if i < paid_installments else \"pending\"\n",
        "            pay_date = current_year_start + timedelta(days=(spacing_days * i) + int(rng.integers(5, 20)))\n",
        "            payment_rows.append({\n",
        "                \"payment_id\": _stable_id(cfg.seed, \"payment\", payment_idx),\n",
        "                \"student_id\": student_id,\n",
        "                \"is_legacy_student\": is_legacy,\n",
        "                \"path\": path,\n",
        "                \"program_year\": program_year,\n",
        "                \"academic_year\": current_year,\n",
        "                \"installment_no\": i + 1,\n",
        "                \"installment_count\": installment_count,\n",
        "                \"amount\": int(amount),\n",
        "                \"payment_plan\": payment_plan,\n",
        "                \"payment_date\": pay_date,\n",
        "                \"payment_method\": str(rng.choice([\"upi\", \"card\", \"net_banking\"])),\n",
        "                \"status\": status,\n",
        "                \"created_at\": run_date,\n",
        "            })\n",
        "            payment_idx += 1\n",
        "            if status == \"paid\":\n",
        "                paid_total += int(amount)\n",
        "\n",
        "        if paid_total <= 0:\n",
        "            paid_total = int(installment_amounts[0])\n",
        "\n",
        "        planned_revenue = cumulative_to_year\n",
        "        actual_revenue = min(paid_total, planned_revenue)\n",
        "        outstanding_amount = int(planned_revenue - actual_revenue)\n",
        "        payment_completion_rate = round((actual_revenue / planned_revenue) * 100, 2)\n",
        "\n",
        "        if outstanding_amount == 0:\n",
        "            collection_status = \"paid_off\"\n",
        "        elif is_legacy or student_status == \"inactive\":\n",
        "            collection_status = \"delinquent\"\n",
        "        else:\n",
        "            collection_status = \"partial\"\n",
        "\n",
        "        finance_rows.append({\n",
        "            \"finance_id\": _stable_id(cfg.seed, \"finance\", len(finance_rows)),\n",
        "            \"student_id\": student_id,\n",
        "            \"is_legacy_student\": is_legacy,\n",
        "            \"student_status\": student_status,\n",
        "            \"path\": path,\n",
        "            \"grade\": int(grade),\n",
        "            \"program_year\": int(program_year),\n",
        "            \"program_duration\": int(program_duration),\n",
        "            \"join_year\": int(join_year),\n",
        "            \"current_year_fee\": int(current_year_fee),\n",
        "            \"planned_revenue\": int(planned_revenue),\n",
        "            \"actual_revenue\": int(actual_revenue),\n",
        "            \"outstanding_amount\": int(outstanding_amount),\n",
        "            \"payment_completion_rate\": payment_completion_rate,\n",
        "            \"current_year_payment_plan\": payment_plan,\n",
        "            \"fee_to_current_year\": int(cumulative_to_year),\n",
        "            \"full_program_fee\": int(full_program_fee),\n",
        "            \"collection_status\": collection_status,\n",
        "            \"updated_at\": run_date,\n",
        "        })\n",
        "\n",
        "    for _, student in df_student.iterrows():\n",
        "        add_financial_record(\n",
        "            student_id=str(student[\"student_id\"]),\n",
        "            path=str(student[\"path\"]),\n",
        "            grade=int(student[\"grade\"]),\n",
        "            program_year=int(student[\"program_year\"]),\n",
        "            program_duration=int(student[\"program_duration\"]),\n",
        "            join_year=int(student[\"join_year\"]),\n",
        "            student_status=str(student[\"status\"]),\n",
        "            is_legacy=False\n",
        "        )\n",
        "\n",
        "    legacy_count = max(cfg.min_legacy_finance_students, int(len(df_student) * cfg.legacy_finance_ratio))\n",
        "    available_paths = sorted(fee_schedule.keys())\n",
        "    for i in range(legacy_count):\n",
        "        path = str(rng.choice(available_paths))\n",
        "        duration = len(fee_schedule[path])\n",
        "        program_year = int(rng.integers(1, duration + 1))\n",
        "        grade = int(fee_schedule[path][program_year - 1][0])\n",
        "        join_year = int(cfg.enrollment_year - (program_year - 1))\n",
        "        legacy_id = \"LEGACY-\" + _stable_id(cfg.seed, \"legacy_student\", i)[:12].upper()\n",
        "        add_financial_record(\n",
        "            student_id=legacy_id,\n",
        "            path=path,\n",
        "            grade=grade,\n",
        "            program_year=program_year,\n",
        "            program_duration=duration,\n",
        "            join_year=join_year,\n",
        "            student_status=\"inactive\",\n",
        "            is_legacy=True\n",
        "        )\n",
        "\n",
        "    return pd.DataFrame(payment_rows), pd.DataFrame(finance_rows)\n",
        "\n",
        "def _material_table(cfg: PipelineConfig, rng: np.random.Generator, df_program: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    material_types = [\"pdf\", \"video\", \"quiz\", \"worksheet\"]\n",
        "    levels = [\"foundation\", \"intermediate\", \"advanced\"]\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, program in df_program.iterrows():\n",
        "        for subject in SUBJECTS:\n",
        "            for module in range(1, 4):\n",
        "                rows.append({\n",
        "                    \"material_id\": _stable_id(cfg.seed, \"material\", idx),\n",
        "                    \"program_id\": program[\"program_id\"],\n",
        "                    \"subject\": subject,\n",
        "                    \"title\": f\"{subject} Module {module}\",\n",
        "                    \"material_type\": str(rng.choice(material_types)),\n",
        "                    \"difficulty_level\": levels[module - 1],\n",
        "                    \"created_at\": run_date,\n",
        "                })\n",
        "                idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def resource_access_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_material: pd.DataFrame) -> pd.DataFrame:\n",
        "    materials_by_program = df_material.groupby(\"program_id\")[\"material_id\"].apply(list).to_dict()\n",
        "    _, end_date = _dataset_window(cfg)\n",
        "    end_dt = datetime.combine(end_date, datetime.min.time()) + timedelta(hours=23, minutes=59)\n",
        "    history_days = _history_days(cfg)\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, student in df_student.iterrows():\n",
        "        program_materials = materials_by_program[str(student[\"program_id\"])]\n",
        "        is_churned = student[\"status\"] == \"inactive\"\n",
        "        is_integrated = str(student[\"path\"]).startswith(\"INT\")\n",
        "\n",
        "        if is_churned:\n",
        "            n_access = int(rng.integers(1, 7))\n",
        "        elif is_integrated:\n",
        "            n_access = int(rng.integers(10, 25))\n",
        "        else:\n",
        "            n_access = int(rng.integers(6, 18))\n",
        "\n",
        "        for _ in range(n_access):\n",
        "            rows.append({\n",
        "                \"access_id\": _stable_id(cfg.seed, \"resource_access\", idx),\n",
        "                \"student_id\": student[\"student_id\"],\n",
        "                \"material_id\": str(rng.choice(program_materials)),\n",
        "                \"access_timestamp\": end_dt - timedelta(days=int(rng.integers(0, history_days + 1)), minutes=int(rng.integers(0, 1440))),\n",
        "                \"duration_seconds\": int(rng.integers(60, 5400 if not is_churned else 1800)),\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _support_ticket_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    categories = [\"technical\", \"academic\", \"billing\", \"counseling\"]\n",
        "    priorities = [\"low\", \"medium\", \"high\"]\n",
        "    history_days = _history_days(cfg)\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, student in df_student.iterrows():\n",
        "        is_churned = student[\"status\"] == \"inactive\"\n",
        "        create_ticket = rng.random() < (0.28 if is_churned else 0.14)\n",
        "        if not create_ticket:\n",
        "            continue\n",
        "        n_tickets = int(rng.integers(1, 4 if is_churned else 3))\n",
        "        for _ in range(n_tickets):\n",
        "            created = run_date - timedelta(days=int(rng.integers(1, history_days + 1)))\n",
        "            status = str(rng.choice([\"closed\", \"open\", \"in_progress\"], p=[0.72, 0.12, 0.16]))\n",
        "            resolved = created + timedelta(days=int(rng.integers(1, 15))) if status == \"closed\" else None\n",
        "            rows.append({\n",
        "                \"ticket_id\": _stable_id(cfg.seed, \"support_ticket\", idx),\n",
        "                \"student_id\": student[\"student_id\"],\n",
        "                \"category\": str(rng.choice(categories)),\n",
        "                \"priority\": str(rng.choice(priorities, p=[0.45, 0.40, 0.15])),\n",
        "                \"status\": status,\n",
        "                \"created_at\": created,\n",
        "                \"resolved_at\": resolved,\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _system_log_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame) -> pd.DataFrame:\n",
        "    events = [\"login\", \"logout\", \"assignment start\", \"resource view\", \"assignment_submit\", \"resource download\", \"quiz_attempt\"]\n",
        "    _, end_date = _dataset_window(cfg)\n",
        "    end_dt = datetime.combine(end_date, datetime.min.time()) + timedelta(hours=23, minutes=59)\n",
        "    history_days = _history_days(cfg)\n",
        "    rows: List[dict] = []\n",
        "    idx = 0\n",
        "    for _, student in df_student.iterrows():\n",
        "        is_churned = student[\"status\"] == \"inactive\"\n",
        "        n_events = int(rng.integers(2, 8) if is_churned else rng.integers(6, 20))\n",
        "        for _ in range(n_events):\n",
        "            rows.append({\n",
        "                \"log_id\": _stable_id(cfg.seed, \"system_log\", idx),\n",
        "                \"user_id\": student[\"student_id\"],\n",
        "                \"event_type\": str(rng.choice(events)),\n",
        "                \"event_timestamp\": end_dt - timedelta(days=int(rng.integers(0, history_days + 1)), minutes=int(rng.integers(0, 1440))),\n",
        "            })\n",
        "            idx += 1\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def retention_action_table(cfg: PipelineConfig, rng: np.random.Generator, df_churn_prediction: pd.DataFrame, run_date: date) -> pd.DataFrame:\n",
        "    action_types = [\"counseling_call\", \"extra_tutoring\", \"study_plan_reset\", \"fee_support\"]\n",
        "    outcomes = [\"effective\", \"ineffective\", \"pending\"]\n",
        "    history_days = _history_days(cfg)\n",
        "    action_window = max(90, min(history_days, 360))\n",
        "\n",
        "    high_risk = df_churn_prediction[df_churn_prediction[\"risk_level\"] == \"high\"].copy()\n",
        "    medium_risk = df_churn_prediction[df_churn_prediction[\"risk_level\"] == \"medium\"].copy()\n",
        "    selected_high = high_risk.sample(frac=0.75, random_state=cfg.seed) if not high_risk.empty else high_risk\n",
        "    selected_medium = medium_risk.sample(frac=0.25, random_state=cfg.seed) if not medium_risk.empty else medium_risk\n",
        "    selected = pd.concat([selected_high, selected_medium], ignore_index=True)\n",
        "\n",
        "    rows: List[dict] = []\n",
        "    for idx, (_, row) in enumerate(selected.iterrows()):\n",
        "        rows.append({\n",
        "            \"action_id\": _stable_id(cfg.seed, \"retention_action\", idx),\n",
        "            \"student_id\": row[\"student_id\"],\n",
        "            \"prediction_id\": row[\"prediction_id\"],\n",
        "            \"risk_level\": row[\"risk_level\"],\n",
        "            \"action_type\": str(rng.choice(action_types)),\n",
        "            \"action_date\": run_date - timedelta(days=int(rng.integers(0, action_window + 1))),\n",
        "            \"outcome\": str(rng.choice(outcomes, p=[0.42, 0.21, 0.37])),\n",
        "            \"notes\": \"Follow-up scheduled\",\n",
        "        })\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "def _student_monthly_features_table(cfg: PipelineConfig, df_student: pd.DataFrame, df_session: pd.DataFrame, df_attendance: pd.DataFrame, df_submission: pd.DataFrame, df_assignment: pd.DataFrame, df_resource_access: pd.DataFrame, df_support_ticket: pd.DataFrame, df_payment_transactions: pd.DataFrame, df_student_metrics: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"Build month-level behavioral features constrained by join date and lifecycle end.\"\"\"\n",
        "    _end_date = _dataset_window(cfg)[1]\n",
        "    end_month_start = pd.Timestamp(_end_date).to_period(\"M\").to_timestamp()\n",
        "    snapshot_rows: List[dict] = []\n",
        "\n",
        "    for _, student in df_student.iterrows():\n",
        "        join_date = date(int(student[\"join_year\"]), 6, 15)\n",
        "        join_month_start = pd.Timestamp(join_date).to_period(\"M\").to_timestamp()\n",
        "        program_end_date = (pd.Timestamp(join_date) + pd.DateOffset(years=int(student[\"program_duration\"]))) - pd.Timedelta(days=1)\n",
        "        program_end_month_start = pd.Timestamp(program_end_date).to_period(\"M\").to_timestamp()\n",
        "        effective_end = min(end_month_start, program_end_month_start)\n",
        "\n",
        "        if effective_end < join_month_start:\n",
        "            continue\n",
        "\n",
        "        month_starts = pd.date_range(start=join_month_start, end=effective_end, freq=\"MS\")\n",
        "        for month_start in month_starts:\n",
        "            snapshot_rows.append({\n",
        "                \"student_id\": student[\"student_id\"],\n",
        "                \"month_start\": month_start,\n",
        "                \"path\": student[\"path\"],\n",
        "                \"grade\": int(student[\"grade\"]),\n",
        "                \"program_year\": int(student[\"program_year\"]),\n",
        "                \"status\": student[\"status\"],\n",
        "                \"join_year\": int(student[\"join_year\"]),\n",
        "                \"program_duration\": int(student[\"program_duration\"]),\n",
        "            })\n",
        "\n",
        "    snapshots = pd.DataFrame(snapshot_rows)\n",
        "    if snapshots.empty:\n",
        "        return pd.DataFrame(columns=[\"monthly_feature_id\", \"student_id\", \"month_start\", \"path\", \"grade\", \"program_year\", \"monthly_attendance_rate\", \"monthly_engagement_avg\", \"sessions_count\", \"monthly_assignment_score_avg\", \"submissions_count\", \"submitted_points\", \"resource_access_count\", \"resource_duration_min\", \"support_ticket_count\", \"high_priority_ticket_count\", \"billed_amount\", \"paid_amount\", \"paid_ratio_month\", \"days_since_last_login\", \"status\", \"status_flag\"])\n",
        "\n",
        "    snapshots[\"month_end\"] = snapshots[\"month_start\"] + pd.offsets.MonthEnd(1)\n",
        "    attendance = df_attendance.copy()\n",
        "    if \"session_date\" not in attendance.columns:\n",
        "        attendance = attendance.merge(df_session[[\"session_id\", \"session_date\"]], on=\"session_id\", how=\"left\")\n",
        "    attendance[\"month_start\"] = pd.to_datetime(attendance[\"session_date\"]).dt.to_period(\"M\").dt.to_timestamp()\n",
        "    att_month = attendance.groupby([\"student_id\", \"month_start\"], as_index=False).agg(monthly_attendance_rate=(\"attended\", \"mean\"), monthly_engagement_avg=(\"engagement_score\", \"mean\"), sessions_count=(\"session_id\", \"nunique\"))\n",
        "\n",
        "    submissions = df_submission.merge(df_assignment[[\"assignment_id\", \"due_date\"]], on=\"assignment_id\", how=\"left\")\n",
        "    submissions[\"month_start\"] = pd.to_datetime(submissions[\"submission_date\"]).dt.to_period(\"M\").dt.to_timestamp()\n",
        "    sub_month = submissions.groupby([\"student_id\", \"month_start\"], as_index=False).agg(monthly_assignment_score_avg=(\"score\", \"mean\"), submissions_count=(\"submission_id\", \"nunique\"), submitted_points=(\"score\", \"sum\"))\n",
        "\n",
        "    access = df_resource_access.copy()\n",
        "    access[\"month_start\"] = pd.to_datetime(access[\"access_timestamp\"]).dt.to_period(\"M\").dt.to_timestamp()\n",
        "    access_month = access.groupby([\"student_id\", \"month_start\"], as_index=False).agg(resource_access_count=(\"access_id\", \"nunique\"), resource_duration_min=(\"duration_seconds\", lambda x: float(x.sum()) / 60.0))\n",
        "\n",
        "    tickets = df_support_ticket.copy()\n",
        "    tickets[\"month_start\"] = pd.to_datetime(tickets[\"created_at\"]).dt.to_period(\"M\").dt.to_timestamp()\n",
        "    ticket_month = tickets.groupby([\"student_id\", \"month_start\"], as_index=False).agg(support_ticket_count=(\"ticket_id\", \"nunique\"), high_priority_ticket_count=(\"priority\", lambda x: int((x == \"high\").sum())))\n",
        "\n",
        "    payments = df_payment_transactions.copy()\n",
        "    payments[\"month_start\"] = pd.to_datetime(payments[\"payment_date\"]).dt.to_period(\"M\").dt.to_timestamp()\n",
        "    payments[\"paid_component\"] = np.where(payments[\"status\"] == \"paid\", payments[\"amount\"], 0)\n",
        "    pay_month = payments.groupby([\"student_id\", \"month_start\"], as_index=False).agg(paid_amount=(\"paid_component\", \"sum\"), billed_amount=(\"amount\", \"sum\"))\n",
        "\n",
        "    snapshots = snapshots.merge(att_month, on=[\"student_id\", \"month_start\"], how=\"left\")\n",
        "    snapshots = snapshots.merge(sub_month, on=[\"student_id\", \"month_start\"], how=\"left\")\n",
        "    snapshots = snapshots.merge(access_month, on=[\"student_id\", \"month_start\"], how=\"left\")\n",
        "    snapshots = snapshots.merge(ticket_month, on=[\"student_id\", \"month_start\"], how=\"left\")\n",
        "    snapshots = snapshots.merge(pay_month, on=[\"student_id\", \"month_start\"], how=\"left\")\n",
        "\n",
        "    metrics = df_student_metrics[[\"student_id\", \"last_login_date\"]].copy()\n",
        "    metrics[\"last_login_date\"] = pd.to_datetime(metrics[\"last_login_date\"])\n",
        "    snapshots = snapshots.merge(metrics, on=\"student_id\", how=\"left\")\n",
        "    snapshots[\"days_since_last_login\"] = (snapshots[\"month_end\"] - snapshots[\"last_login_date\"]).dt.days.clip(lower=0)\n",
        "\n",
        "    numeric_cols = [\"monthly_attendance_rate\", \"monthly_engagement_avg\", \"sessions_count\", \"monthly_assignment_score_avg\", \"submissions_count\", \"submitted_points\", \"resource_access_count\", \"resource_duration_min\", \"support_ticket_count\", \"high_priority_ticket_count\", \"billed_amount\", \"paid_amount\", \"days_since_last_login\"]\n",
        "    for col in numeric_cols:\n",
        "        if col not in snapshots.columns:\n",
        "            snapshots[col] = 0\n",
        "    snapshots[numeric_cols] = snapshots[numeric_cols].fillna(0)\n",
        "\n",
        "    snapshots[\"paid_ratio_month\"] = np.where(snapshots[\"billed_amount\"] > 0, snapshots[\"paid_amount\"] / snapshots[\"billed_amount\"], 0.0)\n",
        "    snapshots[\"status_flag\"] = (snapshots[\"status\"] == \"inactive\").astype(int)\n",
        "    snapshots = snapshots.sort_values([\"student_id\", \"month_start\"]).reset_index(drop=True)\n",
        "    snapshots.insert(0, \"monthly_feature_id\", [_stable_id(cfg.seed, \"monthly_features\", i) for i in range(len(snapshots))])\n",
        "\n",
        "    return snapshots[[\"monthly_feature_id\", \"student_id\", \"month_start\", \"path\", \"grade\", \"program_year\", \"monthly_attendance_rate\", \"monthly_engagement_avg\", \"sessions_count\", \"monthly_assignment_score_avg\", \"submissions_count\", \"submitted_points\", \"resource_access_count\", \"resource_duration_min\", \"support_ticket_count\", \"high_priority_ticket_count\", \"billed_amount\", \"paid_amount\", \"paid_ratio_month\", \"days_since_last_login\", \"status\", \"status_flag\"]]\n",
        "\n",
        "def _validation_report(cfg: PipelineConfig, tables: Dict[str, pd.DataFrame]) -> Dict[str, object]:\n",
        "    \"\"\"Run structural, business rule, and temporal integrity checks across all tables.\"\"\"\n",
        "    errors: List[str] = []\n",
        "\n",
        "    def unique_check(table: str, col: str) -> None:\n",
        "        dupes = int(tables[table][col].duplicated().sum())\n",
        "        if dupes > 0:\n",
        "            errors.append(f\"{table}.{col} has {dupes} duplicate values\")\n",
        "\n",
        "    def fk_check(child: str, fk_col: str, parent: str, pk_col: str) -> None:\n",
        "        mask = ~tables[child][fk_col].isin(tables[parent][pk_col])\n",
        "        bad = int(mask.sum())\n",
        "        if bad > 0:\n",
        "            errors.append(f\"{child}.{fk_col} has {bad} values missing in {parent}.{pk_col}\")\n",
        "\n",
        "    unique_check(\"01_program\", \"program_id\")\n",
        "    unique_check(\"02_faculty\", \"faculty_id\")\n",
        "    unique_check(\"03_cohort\", \"cohort_id\")\n",
        "    unique_check(\"04_student\", \"student_id\")\n",
        "    unique_check(\"05_session\", \"session_id\")\n",
        "    unique_check(\"06_attendance\", \"attendance_id\")\n",
        "    unique_check(\"07_assignment\", \"assignment_id\")\n",
        "    unique_check(\"08_submission\", \"submission_id\")\n",
        "    unique_check(\"09_student_metrics\", \"metric_id\")\n",
        "    unique_check(\"10_churn_prediction\", \"prediction_id\")\n",
        "    unique_check(\"11_feedback\", \"feedback_id\")\n",
        "    unique_check(\"12_payment_transactions\", \"payment_id\")\n",
        "    unique_check(\"13_student_finance\", \"finance_id\")\n",
        "    unique_check(\"14_material\", \"material_id\")\n",
        "    unique_check(\"15_resource_access\", \"access_id\")\n",
        "    unique_check(\"16_support_ticket\", \"ticket_id\")\n",
        "    unique_check(\"17_system_log\", \"log_id\")\n",
        "    unique_check(\"18_retention_action\", \"action_id\")\n",
        "    unique_check(\"19_student_monthly_features\", \"monthly_feature_id\")\n",
        "\n",
        "    fk_check(\"03_cohort\", \"program_id\", \"01_program\", \"program_id\")\n",
        "    fk_check(\"04_student\", \"cohort_id\", \"03_cohort\", \"cohort_id\")\n",
        "    fk_check(\"04_student\", \"program_id\", \"01_program\", \"program_id\")\n",
        "    fk_check(\"05_session\", \"cohort_id\", \"03_cohort\", \"cohort_id\")\n",
        "    fk_check(\"06_attendance\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"06_attendance\", \"session_id\", \"05_session\", \"session_id\")\n",
        "    fk_check(\"07_assignment\", \"cohort_id\", \"03_cohort\", \"cohort_id\")\n",
        "    fk_check(\"08_submission\", \"assignment_id\", \"07_assignment\", \"assignment_id\")\n",
        "    fk_check(\"08_submission\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"09_student_metrics\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"10_churn_prediction\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"11_feedback\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"14_material\", \"program_id\", \"01_program\", \"program_id\")\n",
        "    fk_check(\"15_resource_access\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"15_resource_access\", \"material_id\", \"14_material\", \"material_id\")\n",
        "    fk_check(\"16_support_ticket\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"17_system_log\", \"user_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"18_retention_action\", \"student_id\", \"04_student\", \"student_id\")\n",
        "    fk_check(\"18_retention_action\", \"prediction_id\", \"10_churn_prediction\", \"prediction_id\")\n",
        "    fk_check(\"19_student_monthly_features\", \"student_id\", \"04_student\", \"student_id\")\n",
        "\n",
        "    if len(tables[\"04_student\"]) <= 5000:\n",
        "        errors.append(\"04_student must contain more than 5000 students\")\n",
        "\n",
        "    over_cap = tables[\"03_cohort\"][tables[\"03_cohort\"][\"total_students\"] > cfg.standalone_max_students]\n",
        "    if not over_cap.empty:\n",
        "        errors.append(f\"03_cohort has {len(over_cap)} cohorts above cap {cfg.standalone_max_students}\")\n",
        "\n",
        "    integrated = tables[\"03_cohort\"][tables[\"03_cohort\"][\"path\"].str.startswith(\"INT\")].copy()\n",
        "    for path, group in integrated.groupby(\"path\"):\n",
        "        ordered = group.sort_values(\"program_year\")\n",
        "        diffs = ordered[\"total_students\"].diff().fillna(0)\n",
        "        if (diffs > 0).any():\n",
        "            errors.append(f\"03_cohort has increasing student count across years for integrated path {path}\")\n",
        "\n",
        "    email_has_cy = int(tables[\"04_student\"][\"email\"].str.contains(r\"\\.cy\\d+@\", regex=True).sum())\n",
        "    if email_has_cy > 0:\n",
        "        errors.append(f\"04_student has {email_has_cy} emails containing disallowed current-year suffix\")\n",
        "\n",
        "    submission_with_due = tables[\"08_submission\"].merge(tables[\"07_assignment\"][[\"assignment_id\", \"due_date\"]], on=\"assignment_id\", how=\"left\")\n",
        "    bad_submission_dates = int((submission_with_due[\"submission_date\"] > submission_with_due[\"due_date\"]).sum())\n",
        "    if bad_submission_dates > 0:\n",
        "        errors.append(f\"08_submission has {bad_submission_dates} records where submission_date > due_date\")\n",
        "\n",
        "    _, end_date = _dataset_window(cfg)\n",
        "    future_submissions = int((pd.to_datetime(tables[\"08_submission\"][\"submission_date\"]).dt.date > end_date).sum())\n",
        "    if future_submissions > 0:\n",
        "        errors.append(f\"08_submission has {future_submissions} records after dataset end date {end_date}\")\n",
        "\n",
        "    future_assignment_due = int((pd.to_datetime(tables[\"07_assignment\"][\"due_date\"]).dt.date > end_date).sum())\n",
        "    if future_assignment_due > 0:\n",
        "        errors.append(f\"07_assignment has {future_assignment_due} due dates after dataset end date {end_date}\")\n",
        "\n",
        "    session_dates = tables[\"05_session\"].copy()\n",
        "    session_dates[\"session_date\"] = pd.to_datetime(session_dates[\"session_date\"])\n",
        "    future_sessions = int((session_dates[\"session_date\"].dt.date > end_date).sum())\n",
        "    if future_sessions > 0:\n",
        "        errors.append(f\"05_session has {future_sessions} session dates after dataset end date {end_date}\")\n",
        "\n",
        "    session_span = session_dates.groupby(\"cohort_id\")[\"session_date\"].agg([\"min\", \"max\"])\n",
        "    min_expected_span = int(_history_days(cfg) * 0.8)\n",
        "    short_span = int(((session_span[\"max\"] - session_span[\"min\"]).dt.days < min_expected_span).sum())\n",
        "    if short_span > 0:\n",
        "        errors.append(f\"05_session has {short_span} cohorts with less than expected history span ({min_expected_span} days)\")\n",
        "\n",
        "    monthly = tables[\"19_student_monthly_features\"].copy()\n",
        "    monthly[\"month_start\"] = pd.to_datetime(monthly[\"month_start\"])\n",
        "    monthly_span = monthly.groupby(\"student_id\")[\"month_start\"].agg([\"min\", \"max\", \"nunique\"]).reset_index()\n",
        "    students = tables[\"04_student\"][[\"student_id\", \"join_year\", \"program_duration\"]].copy()\n",
        "    students[\"join_month\"] = pd.to_datetime(students[\"join_year\"].astype(str) + \"-06-01\")\n",
        "    students[\"program_end_month\"] = students.apply(lambda r: (r[\"join_month\"] + pd.DateOffset(years=int(r[\"program_duration\"])) - pd.Timedelta(days=1)).to_period(\"M\").to_timestamp(), axis=1)\n",
        "    students[\"dataset_end_month\"] = pd.Timestamp(end_date).to_period(\"M\").to_timestamp()\n",
        "    students[\"expected_last_month\"] = students[[\"program_end_month\", \"dataset_end_month\"]].min(axis=1)\n",
        "\n",
        "    monthly_check = monthly_span.merge(students[[\"student_id\", \"join_month\", \"expected_last_month\"]], on=\"student_id\", how=\"left\")\n",
        "    bad_before_join = int((monthly_check[\"min\"] < monthly_check[\"join_month\"]).sum())\n",
        "    if bad_before_join > 0:\n",
        "        errors.append(f\"19_student_monthly_features has {bad_before_join} students with months before join month\")\n",
        "    bad_after_end = int((monthly_check[\"max\"] > monthly_check[\"expected_last_month\"]).sum())\n",
        "    if bad_after_end > 0:\n",
        "        errors.append(f\"19_student_monthly_features has {bad_after_end} students with months after allowed program/as-of end\")\n",
        "\n",
        "    finance = tables[\"13_student_finance\"].copy()\n",
        "    payments = tables[\"12_payment_transactions\"].copy()\n",
        "    if len(finance) < len(tables[\"04_student\"]):\n",
        "        errors.append(\"13_student_finance should include at least all student records\")\n",
        "    non_positive_actual = int((finance[\"actual_revenue\"] <= 0).sum())\n",
        "    if non_positive_actual > 0:\n",
        "        errors.append(f\"13_student_finance has {non_positive_actual} records with non-positive actual revenue\")\n",
        "    overpaid = int((finance[\"actual_revenue\"] > finance[\"planned_revenue\"]).sum())\n",
        "    if overpaid > 0:\n",
        "        errors.append(f\"13_student_finance has {overpaid} records with actual_revenue > planned_revenue\")\n",
        "    bad_outstanding = int((finance[\"outstanding_amount\"] != (finance[\"planned_revenue\"] - finance[\"actual_revenue\"]).astype(int)).sum())\n",
        "    if bad_outstanding > 0:\n",
        "        errors.append(f\"13_student_finance has {bad_outstanding} rows with incorrect outstanding_amount\")\n",
        "    bad_cumulative = int((finance[\"planned_revenue\"] != finance[\"fee_to_current_year\"]).sum())\n",
        "    if bad_cumulative > 0:\n",
        "        errors.append(f\"13_student_finance has {bad_cumulative} rows where planned_revenue is not cumulative\")\n",
        "    bad_duration = int((finance[\"program_year\"] > finance[\"program_duration\"]).sum())\n",
        "    if bad_duration > 0:\n",
        "        errors.append(f\"13_student_finance has {bad_duration} rows with program_year > program_duration\")\n",
