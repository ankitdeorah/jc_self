def _stable_id(seed: int, entity: str, idx: int) -> str:
    return str(uuid.uuid5(uuid.NAMESPACE_URL, f"{seed}:{entity}:{idx}"))

def _name_pool(rng: np.random.Generator, count: int) -> List[str]:
    combos = [f"{f} {l}" for f in FIRST_NAMES for l in LAST_NAMES]
    if count > len(combos):
        raise ValueError("Name pool is too small for requested unique names")
    picks = rng.choice(len(combos), size=count, replace=False)
    return [combos[int(i)] for i in picks]

def _email_from_name(name: str, domain: str = "academy.com") -> str:
    clean = re.sub(r"[^A-Za-z]", "", name)
    slug = re.sub(r"\s+", ".", clean.strip().lower())
    slug = re.sub(r"\.+", ".", slug).strip(".")
    return f"{slug}@{domain}"

def _path_meta(path: str, grade: int) -> Tuple[int, int, int, int, bool]:
    if path.startswith("SA"):
        return grade, grade, 1, 1, False
    parts = path.split("-")
    start_grade = int(parts[1])
    end_grade = int(parts[2])
    program_year = grade - start_grade + 1
    duration = end_grade - start_grade + 1
    return start_grade, end_grade, duration, program_year, True

def _split_amount(total: int, parts: int) -> List[int]:
    base = total // parts
    remainder = total % (base * parts) if base > 0 else total
    return [base + (1 if i < remainder else 0) for i in range(parts)]

def _effective_history_months(cfg: PipelineConfig) -> int:
    return int(min(24, max(12, cfg.history_months)))

def _dataset_window(cfg: PipelineConfig) -> Tuple[date, date]:
    """Return the bounded generation window based on config and optional as-of date."""
    start_date = date(cfg.enrollment_year, 6, 15)
    requested_end = start_date + timedelta(days=(_effective_history_months(cfg) * 30)-1)
    if cfg.as_of_date:
        try:
            as_of = datetime.strptime(cfg.as_of_date, "%Y-%m-%d").date()
        except ValueError as exc:
            raise ValueError("as_of_date must be in YYYY-MM-DD format") from exc
    else:
        as_of = datetime.now().date()
    end_date = min(as_of, requested_end)
    if end_date < start_date:
        end_date = start_date
    return start_date, end_date

def _history_days(cfg: PipelineConfig) -> int:
    start, end = _dataset_window(cfg)
    return int(max(1, (end - start).days + 1))

def _months_available(cfg: PipelineConfig) -> int:
    start, end = _dataset_window(cfg)
    return int(max(1, ((end.year - start.year) * 12 + (end.month - start.month) + 1)))

def _program_table(cfg: PipelineConfig, run_date: date) -> pd.DataFrame:
    rows: List[dict] = []
    start_date, _ = _dataset_window(cfg)
    for i, p in enumerate(PROGRAM_CONFIGS):
        start_grade, end_grade, duration, program_year, is_integrated = _path_meta(p["path"], p["grade"])
        rows.append({
            "program_id": _stable_id(cfg.seed, "program", i),
            "name": p["name"],
            "path": p["path"],
            "grade": int(p["grade"]),
            "batch_start_date": start_date,
            "annual_fee": int(p["fee"]),
            "path_start_grade": int(start_grade),
            "path_end_grade": int(end_grade),
            "program_duration": int(duration),
            "program_year": int(program_year),
            "is_integrated": bool(is_integrated),
            "created_at": run_date,
            "updated_at": run_date,
        })
    return pd.DataFrame(rows)

def _faculty_table(cfg: PipelineConfig, rng: np.random.Generator, run_date: date) -> pd.DataFrame:
    total_people = 1 + 4 + 4 + 5 + max(50, cfg.num_teachers)
    names = _name_pool(rng, total_people)
    rows: List[dict] = []
    idx = 0

    dean_name = f"Dr. {names[idx]}"
    rows.append({
        "faculty_id": _stable_id(cfg.seed, "faculty", idx),
        "name": dean_name,
        "role": "Dean",
        "role_group": "Leadership",
        "expertise": "Academic Strategy",
        "teaches_grades": "",
        "hierarchy_level": 1,
        "email": _email_from_name(dean_name),
        "created_at": run_date,
    })
    idx += 1

    for subject in SUBJECTS:
        hod_name = f"Dr. {names[idx]}"
        rows.append({
            "faculty_id": _stable_id(cfg.seed, "faculty", idx),
            "name": hod_name,
            "role": "HOD",
            "role_group": "Leadership",
            "expertise": subject,
            "teaches_grades": "",
            "hierarchy_level": 2,
            "email": _email_from_name(hod_name),
            "created_at": run_date,
        })
        idx += 1

    counselor_domains = ["Mental Wellness", "Professional Development", "Behavioral Science", "Career Guidance"]
    for domain in counselor_domains:
        name = names[idx]
        rows.append({
            "faculty_id": _stable_id(cfg.seed, "faculty", idx),
            "name": name,
            "role": "Student Counselor",
            "role_group": "Student Success",
            "expertise": domain,
            "teaches_grades": "",
            "hierarchy_level": 3,
            "email": _email_from_name(name),
            "created_at": run_date,
        })
        idx += 1

    for coordinator_no in range(1, 6):
        name = names[idx]
        rows.append({
            "faculty_id": _stable_id(cfg.seed, "faculty", idx),
            "name": name,
            "role": "Course Coordinator",
            "role_group": "Administration",
            "expertise": f"Cohort Operations {coordinator_no}",
            "teaches_grades": "",
            "hierarchy_level": 3,
            "email": _email_from_name(name),
            "created_at": run_date,
        })
        idx += 1

    teacher_count = max(50, cfg.num_teachers)
    senior_count = max(18, int(round(teacher_count * 0.44)))
    junior_count = teacher_count - senior_count
    doctorate_senior_count = min(6, max(3, senior_count // 4))

    for teacher_idx in range(senior_count):
        base_name = names[idx]
        name = f"Dr. {base_name}" if teacher_idx < doctorate_senior_count else base_name
        rows.append({
            "faculty_id": _stable_id(cfg.seed, "faculty", idx),
            "name": name,
            "role": "Senior Faculty",
            "role_group": "Teaching",
            "expertise": str(rng.choice(SUBJECTS)),
            "teaches_grades": "11,12",
            "hierarchy_level": 4,
            "email": _email_from_name(name),
            "created_at": run_date,
        })
        idx += 1

    for _ in range(junior_count):
        name = names[idx]
        rows.append({
            "faculty_id": _stable_id(cfg.seed, "faculty", idx),
            "name": name,
            "role": "Junior Faculty",
            "role_group": "Teaching",
            "expertise": str(rng.choice(SUBJECTS)),
            "teaches_grades": "9,10",
            "hierarchy_level": 4,
            "email": _email_from_name(name),
            "created_at": run_date,
        })
        idx += 1
    return pd.DataFrame(rows)

def integrated_profile_counts(intake: int, retentions: List[float], min_count: int) -> List[int]:
    counts = [int(intake)]
    current = float(intake)
    for retention in retentions:
        current = max(float(min_count), round(current * retention))
        counts.append(int(current))
    return counts

def cohort_table(cfg: PipelineConfig, rng: np.random.Generator, df_program: pd.DataFrame) -> pd.DataFrame:
    """Allocate student counts per cohort with caps and integrated-path retention shape."""
    cap = int(cfg.standalone_max_students)
    minimum_target = max(5001, cfg.num_students_target)
    desired_total = min(cap * len(df_program), minimum_target + int(rng.integers(30, 151)))

    standalone = df_program[df_program["path"].str.startswith("SA")].copy()
    integrated = df_program[df_program["path"].str.startswith("INT")].copy()
    standalone_counts: Dict[str, int] = {}

    for _, program in standalone.iterrows():
        standalone_counts[str(program["program_id"])] = int(rng.integers(340, min(cap, 430) + 1))

    integrated_profiles: Dict[str, dict] = {}
    for path, grp in integrated.groupby("path"):
        ordered = grp.sort_values("grade")
        duration = int(len(ordered))
        if duration == 4:
            intake_low, intake_high = 405, min(cap, 440)
            retention_low, retention_high = 0.92, 0.97
        elif duration == 3:
            intake_low, intake_high = 400, min(cap, 438)
            retention_low, retention_high = 0.915, 0.968
        else:
            intake_low, intake_high = 395, min(cap, 435)
            retention_low, retention_high = 0.91, 0.965

        integrated_profiles[path] = {
            "program_ids": list(ordered["program_id"]),
            "intake": int(rng.integers(intake_low, intake_high + 1)),
            "retentions": [float(rng.uniform(retention_low, retention_high)) for _ in range(duration - 1)],
            "min_count": 220,
        }

    def build_counts() -> Tuple[int, Dict[str, int]]:
        counts: Dict[str, int] = {}
        for pid, count in standalone_counts.items():
            counts[pid] = min(cap, int(count))
        for profile in integrated_profiles.values():
            path_counts = integrated_profile_counts(profile["intake"], profile["retentions"], profile["min_count"])
            for i, pid in enumerate(profile["program_ids"]):
                counts[str(pid)] = min(cap, int(path_counts[i]))
        return int(sum(counts.values())), counts

    total_students, all_counts = build_counts()
    iterations = 0
    path_keys = sorted(integrated_profiles.keys())

    while total_students < desired_total and iterations < 5000:
        boost_standalone = bool(rng.random() < 0.35)
        if boost_standalone:
            eligible_sa = [pid for pid, value in standalone_counts.items() if value < cap]
            if eligible_sa:
                chosen = str(rng.choice(eligible_sa))
                standalone_counts[chosen] += 1
            else:
                boost_standalone = False
        if not boost_standalone:
            eligible_paths = [path for path in path_keys if integrated_profiles[path]["intake"] < cap]
            if eligible_paths:
                chosen_path = str(rng.choice(eligible_paths))
                integrated_profiles[chosen_path]["intake"] += 1
            else:
                for path in path_keys:
                    rets = integrated_profiles[path]["retentions"]
                    for r_idx in range(len(rets)):
                        rets[r_idx] = min(0.985, rets[r_idx] + 0.0005)
        total_students, all_counts = build_counts()
        iterations += 1

    if total_students < minimum_target:
        raise ValueError("Unable to satisfy student target while honoring cohort caps")

    rows: List[dict] = []
    for i, (_, program) in enumerate(df_program.iterrows()):
        pid = str(program["program_id"])
        rows.append({
            "cohort_id": _stable_id(cfg.seed, "cohort", i),
            "program_id": program["program_id"],
            "path": program["path"],
            "grade": int(program["grade"]),
            "program_year": int(program["program_year"]),
            "program_duration": int(program["program_duration"]),
            "total_students": int(all_counts[pid]),
            "start_date": program["batch_start_date"],
        })
    return pd.DataFrame(rows)

def student_table(cfg: PipelineConfig, rng: np.random.Generator, df_cohort: pd.DataFrame) -> pd.DataFrame:
    rows: List[dict] = []
    idx = 0
    for _, cohort in df_cohort.iterrows():
        path = str(cohort["path"])
        grade = int(cohort["grade"])
        program_year = int(cohort["program_year"])
        program_duration = int(cohort["program_duration"])
        join_year = int(cfg.enrollment_year - (program_year - 1))
        path_code = path.lower().replace("-", "")

        for i in range(int(cohort["total_students"])):
            first = str(rng.choice(FIRST_NAMES))
            last = str(rng.choice(LAST_NAMES))
            churn_prob = cfg.churn_ratio + (0.03 * (program_year - 1) if path.startswith("INT") else 0.01 * (grade - 9))
            churn_prob = min(0.35, max(0.05, churn_prob))
            status = "inactive" if rng.random() < churn_prob else "active"

            rows.append({
                "student_id": _stable_id(cfg.seed, "student", idx),
                "name": f"{first} {last}",
                "email": f"{first.lower()}.{last.lower()}.{i}.{path_code}.jy{join_year}@student.academy.com",
                "program_id": cohort["program_id"],
                "program_year": program_year,
                "program_duration": program_duration,
                "join_year": join_year,
                "cohort_id": cohort["cohort_id"],
                "path": path,
                "grade": grade,
                "status": status,
            })
            idx += 1
    return pd.DataFrame(rows)

def _session_table(cfg: PipelineConfig, rng: np.random.Generator, df_cohort: pd.DataFrame) -> pd.DataFrame:
    start_date, end_date = _dataset_window(cfg)
    history_weeks = int(np.ceil(_history_days(cfg) / 7))
    total_weeks = max(1, max(cfg.session_weeks, history_weeks))
    rows: List[dict] = []
    idx = 0

    for _, cohort in df_cohort.iterrows():
        for week in range(total_weeks):
            session_date = cohort["start_date"] + timedelta(days=week * 7)
            if session_date > end_date:
                break
            rows.append({
                "session_id": _stable_id(cfg.seed, "session", idx),
                "cohort_id": cohort["cohort_id"],
                "session_number": week + 1,
                "topic": str(rng.choice(TOPIC_BANK)),
                "session_date": session_date,
            })
            idx += 1
    return pd.DataFrame(rows)

def _attendance_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_session: pd.DataFrame, run_date: date) -> pd.DataFrame:
    session_lists = (
        df_session.sort_values(["cohort_id", "session_date"])
        .groupby("cohort_id", sort=False)
        .agg({"session_id": list, "session_date": list})
    )
    sessions_by_cohort = {
        cohort_id: list(zip(row["session_id"], row["session_date"]))
        for cohort_id, row in session_lists.iterrows()
    }

    rows: List[dict] = []
    idx = 0
    for _, student in df_student.iterrows():
        is_churned = student["status"] == "inactive"
        is_integrated = str(student["path"]).startswith("INT")
        p_attended = 0.25 if is_churned else (0.90 if is_integrated else 0.84)

        for session_id, session_date in sessions_by_cohort[student["cohort_id"]]:
            attended = bool(rng.random() < p_attended)
            if not attended:
                engagement = 0
            elif is_churned:
                engagement = int(rng.integers(12, 52))
            elif is_integrated:
                engagement = int(rng.integers(68, 100))
            else:
                engagement = int(rng.integers(60, 96))

            rows.append({
                "attendance_id": _stable_id(cfg.seed, "attendance", idx),
                "student_id": student["student_id"],
                "session_id": session_id,
                "session_date": session_date,
                "attendance_month": pd.Timestamp(session_date).to_period("M").strftime("%Y-%m"),
                "attended": attended,
                "engagement_score": engagement,
                "created_at": run_date,
                "updated_at": run_date,
            })
            idx += 1
    return pd.DataFrame(rows)

def _assignment_table(cfg: PipelineConfig, df_cohort: pd.DataFrame, run_date: date) -> pd.DataFrame:
    assignment_kinds = [
        "Monthly Quiz", "Practice Test", "Concept Drill", "Revision Worksheet",
        "Timed Assessment", "Application Problem Set"
    ]
    _, end_date = _dataset_window(cfg)
    total_assignments = max(1, min(max(cfg.assignment_count, _effective_history_months(cfg)), _months_available(cfg)))

    rows: List[dict] = []
    idx = 0
    for _, cohort in df_cohort.iterrows():
        for month_idx in range(total_assignments):
            kind = assignment_kinds[month_idx % len(assignment_kinds)]
            due_date = cohort["start_date"] + timedelta(days=(month_idx + 1) * 30)
            if due_date > end_date:
                break
            rows.append({
                "assignment_id": _stable_id(cfg.seed, "assignment", idx),
                "cohort_id": cohort["cohort_id"],
                "title": f"{kind} {month_idx + 1}",
                "max_points": 100,
                "due_date": due_date,
                "weightage": round(1 / total_assignments, 3),
                "created_at": run_date,
                "updated_at": run_date,
            })
            idx += 1
    return pd.DataFrame(rows)

def _submission_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_assignment: pd.DataFrame, run_date: date) -> pd.DataFrame:
    students_by_cohort = {cohort_id: group.to_dict("records") for cohort_id, group in df_student.groupby("cohort_id")}
    rows: List[dict] = []
    idx = 0
    for _, assignment in df_assignment.iterrows():
        for student in students_by_cohort[assignment["cohort_id"]]:
            is_churned = student["status"] == "inactive"
            is_integrated = str(student["path"]).startswith("INT")
            submit_prob = 0.42 if is_churned else (0.96 if is_integrated else 0.92)

            if rng.random() >= submit_prob:
                continue

            if is_churned:
                score = int(rng.integers(20, 61))
            elif is_integrated:
                score = int(rng.integers(72, 101))
            else:
                score = int(rng.integers(65, 99))

            rows.append({
                "submission_id": _stable_id(cfg.seed, "submission", idx),
                "assignment_id": assignment["assignment_id"],
                "student_id": student["student_id"],
                "submission_date": assignment["due_date"] - timedelta(days=int(rng.integers(0, 7))),
                "score": score,
                "status": "graded",
                "created_at": run_date,
                "updated_at": run_date,
            })
            idx += 1
    return pd.DataFrame(rows)

def _student_metrics_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_attendance: pd.DataFrame, df_submission: pd.DataFrame, run_date: date) -> pd.DataFrame:
    score_by_student = df_submission.groupby("student_id")["score"].mean()
    attendance_pct = df_attendance.groupby("student_id")["attended"].mean() * 100
    engagement_avg = df_attendance.groupby("student_id")["engagement_score"].mean()

    rows: List[dict] = []
    for idx, (_, student) in enumerate(df_student.iterrows()):
        is_churned = student["status"] == "inactive"
        idle_days = int(rng.integers(40, 181) if is_churned else rng.integers(0, 60))
        avg_score = float(score_by_student.get(student["student_id"], np.nan))
        if np.isnan(avg_score):
            avg_score = 35.0 if is_churned else 74.0

        attendance = float(attendance_pct.get(student["student_id"], np.nan))
        if np.isnan(attendance):
            attendance = 22.0 if is_churned else 78.0

        engagement = float(engagement_avg.get(student["student_id"], np.nan))
        if np.isnan(engagement):
            engagement = 28.0 if is_churned else 76.0

        rows.append({
            "student_id": student["student_id"],
            "metric_id": _stable_id(cfg.seed, "student_metric", idx),
            "avg_assignment_score": round(avg_score, 2),
            "attendance_percentage": round(attendance, 2),
            "avg_engagement_score": round(engagement, 2),
            "last_login_date": run_date - timedelta(days=idle_days),
            "updated_at": run_date,
        })
    return pd.DataFrame(rows)

def churn_prediction_table(cfg: PipelineConfig, df_student_metrics: pd.DataFrame, run_date: date) -> pd.DataFrame:
    rows: List[dict] = []
    for idx, (_, metric) in enumerate(df_student_metrics.iterrows()):
        att = float(metric["attendance_percentage"])
        score = float(metric["avg_assignment_score"])
        engagement = float(metric["avg_engagement_score"])
        recency = float((run_date - metric["last_login_date"]).days)

        logit = -1.2 + (52 - att) * 0.055 + (60 - score) * 0.035 + (56 - engagement) * 0.03 + recency * 0.01
        probability = float(1/(1 + np.exp(-logit)))
        probability = max(0.01, min(0.99, probability))

        if probability > 0.70:
            risk = "high"
        elif probability > 0.35:
            risk = "medium"
        else:
            risk = "low"

        rows.append({
            "prediction_id": _stable_id(cfg.seed, "churn_prediction", idx),
            "student_id": metric["student_id"],
            "churn_probability": round(probability, 4),
            "risk_level": risk,
            "predicted_at": run_date,
        })
    return pd.DataFrame(rows)

def feedback_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, run_date: date) -> pd.DataFrame:
    comments = [
        "Very helpful", "Good pace", "Too difficult", "Content too fast",
        "Excellent support", "Counseling support is useful", "Need more practice tests"
    ]
    sample = df_student.sample(frac=0.32, random_state=cfg.seed)
    rows: List[dict] = []
    for idx, (_, student) in enumerate(sample.iterrows()):
        is_churned = student["status"] == "inactive"
        rows.append({
            "feedback_id": _stable_id(cfg.seed, "feedback", idx),
            "student_id": student["student_id"],
            "rating": int(rng.integers(1, 4) if is_churned else rng.integers(3, 6)),
            "comments": str(rng.choice(comments)),
            "created_at": run_date,
        })
    return pd.DataFrame(rows)

def _fee_schedules(df_program: pd.DataFrame) -> Dict[str, List[Tuple[int, int]]]:
    schedules: Dict[str, List[Tuple[int, int]]] = {}
    for path, group in df_program.groupby("path"):
        ordered = group.sort_values("grade")
        schedules[path] = [(int(r["grade"]), int(r["annual_fee"])) for _, r in ordered.iterrows()]
    return schedules

def payment_and_finance_tables(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_program: pd.DataFrame, run_date: date) -> Tuple[pd.DataFrame, pd.DataFrame]:
    fee_schedule = _fee_schedules(df_program)
    payment_rows: List[dict] = []
    finance_rows: List[dict] = []
    payment_idx = 0

    def add_financial_record(student_id: str, path: str, grade: int, program_year: int, program_duration: int, join_year: int, student_status: str, is_legacy: bool) -> None:
        nonlocal payment_idx
        schedule = fee_schedule[path]
        year_fees = [fee[1] for fee in schedule]
        current_year_fee = int(year_fees[program_year - 1])
        cumulative_to_year = int(sum(year_fees[:program_year]))
        full_program_fee = int(sum(year_fees))
        paid_total = 0

        for prior_year in range(program_year - 1):
            prior_fee = int(year_fees[prior_year])
            academic_year = int(join_year + prior_year)
            pay_date = date(academic_year, 6, 15) + timedelta(days=int(rng.integers(10,45)))
            payment_rows.append({
                "payment_id": _stable_id(cfg.seed, "payment", payment_idx),
                "student_id": student_id,
                "is_legacy_student": is_legacy,
                "path": path,
                "program_year": prior_year + 1,
                "academic_year": academic_year,
                "installment_no": 1,
                "installment_count": 1,
                "amount": prior_fee,
                "payment_plan": "annual",
                "payment_date": pay_date,
                "payment_method": str(rng.choice(["upi", "card", "net banking"])),
                "status": "paid",
                "created_at": run_date,
            })
            payment_idx += 1
            paid_total += prior_fee

        payment_plan = str(rng.choice(["quarterly", "half_yearly", "annual"], p=[0.45, 0.35, 0.20]))
        installment_count = {"quarterly": 4, "half_yearly": 2, "annual": 1}[payment_plan]
        installment_amounts = _split_amount(current_year_fee, installment_count)

        if is_legacy:
            max_paid = max(1, installment_count - 1)
            paid_installments = int(rng.integers(1, max_paid + 1))
        elif student_status == "inactive":
            paid_installments = int(rng.integers(1, installment_count + 1))
        else:
            min_paid = 1 if installment_count == 1 else int(np.ceil(installment_count / 2))
            paid_installments = int(rng.integers(min_paid, installment_count + 1))

        spacing_days = {"quarterly": 90, "half_yearly": 180, "annual": 0}[payment_plan]
        current_year = int(cfg.enrollment_year)
        current_year_start = date(current_year, 6, 15)

        for i, amount in enumerate(installment_amounts):
            status = "paid" if i < paid_installments else "pending"
            pay_date = current_year_start + timedelta(days=(spacing_days * i) + int(rng.integers(5, 20)))
            payment_rows.append({
                "payment_id": _stable_id(cfg.seed, "payment", payment_idx),
                "student_id": student_id,
                "is_legacy_student": is_legacy,
                "path": path,
                "program_year": program_year,
                "academic_year": current_year,
                "installment_no": i + 1,
                "installment_count": installment_count,
                "amount": int(amount),
                "payment_plan": payment_plan,
                "payment_date": pay_date,
                "payment_method": str(rng.choice(["upi", "card", "net_banking"])),
                "status": status,
                "created_at": run_date,
            })
            payment_idx += 1
            if status == "paid":
                paid_total += int(amount)

        if paid_total <= 0:
            paid_total = int(installment_amounts[0])

        planned_revenue = cumulative_to_year
        actual_revenue = min(paid_total, planned_revenue)
        outstanding_amount = int(planned_revenue - actual_revenue)
        payment_completion_rate = round((actual_revenue / planned_revenue) * 100, 2)

        if outstanding_amount == 0:
            collection_status = "paid_off"
        elif is_legacy or student_status == "inactive":
            collection_status = "delinquent"
        else:
            collection_status = "partial"

        finance_rows.append({
            "finance_id": _stable_id(cfg.seed, "finance", len(finance_rows)),
            "student_id": student_id,
            "is_legacy_student": is_legacy,
            "student_status": student_status,
            "path": path,
            "grade": int(grade),
            "program_year": int(program_year),
            "program_duration": int(program_duration),
            "join_year": int(join_year),
            "current_year_fee": int(current_year_fee),
            "planned_revenue": int(planned_revenue),
            "actual_revenue": int(actual_revenue),
            "outstanding_amount": int(outstanding_amount),
            "payment_completion_rate": payment_completion_rate,
            "current_year_payment_plan": payment_plan,
            "fee_to_current_year": int(cumulative_to_year),
            "full_program_fee": int(full_program_fee),
            "collection_status": collection_status,
            "updated_at": run_date,
        })

    for _, student in df_student.iterrows():
        add_financial_record(
            student_id=str(student["student_id"]),
            path=str(student["path"]),
            grade=int(student["grade"]),
            program_year=int(student["program_year"]),
            program_duration=int(student["program_duration"]),
            join_year=int(student["join_year"]),
            student_status=str(student["status"]),
            is_legacy=False
        )

    legacy_count = max(cfg.min_legacy_finance_students, int(len(df_student) * cfg.legacy_finance_ratio))
    available_paths = sorted(fee_schedule.keys())
    for i in range(legacy_count):
        path = str(rng.choice(available_paths))
        duration = len(fee_schedule[path])
        program_year = int(rng.integers(1, duration + 1))
        grade = int(fee_schedule[path][program_year - 1][0])
        join_year = int(cfg.enrollment_year - (program_year - 1))
        legacy_id = "LEGACY-" + _stable_id(cfg.seed, "legacy_student", i)[:12].upper()
        add_financial_record(
            student_id=legacy_id,
            path=path,
            grade=grade,
            program_year=program_year,
            program_duration=duration,
            join_year=join_year,
            student_status="inactive",
            is_legacy=True
        )

    return pd.DataFrame(payment_rows), pd.DataFrame(finance_rows)

def _material_table(cfg: PipelineConfig, rng: np.random.Generator, df_program: pd.DataFrame, run_date: date) -> pd.DataFrame:
    material_types = ["pdf", "video", "quiz", "worksheet"]
    levels = ["foundation", "intermediate", "advanced"]
    rows: List[dict] = []
    idx = 0
    for _, program in df_program.iterrows():
        for subject in SUBJECTS:
            for module in range(1, 4):
                rows.append({
                    "material_id": _stable_id(cfg.seed, "material", idx),
                    "program_id": program["program_id"],
                    "subject": subject,
                    "title": f"{subject} Module {module}",
                    "material_type": str(rng.choice(material_types)),
                    "difficulty_level": levels[module - 1],
                    "created_at": run_date,
                })
                idx += 1
    return pd.DataFrame(rows)

def resource_access_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, df_material: pd.DataFrame) -> pd.DataFrame:
    materials_by_program = df_material.groupby("program_id")["material_id"].apply(list).to_dict()
    _, end_date = _dataset_window(cfg)
    end_dt = datetime.combine(end_date, datetime.min.time()) + timedelta(hours=23, minutes=59)
    history_days = _history_days(cfg)
    rows: List[dict] = []
    idx = 0
    for _, student in df_student.iterrows():
        program_materials = materials_by_program[str(student["program_id"])]
        is_churned = student["status"] == "inactive"
        is_integrated = str(student["path"]).startswith("INT")

        if is_churned:
            n_access = int(rng.integers(1, 7))
        elif is_integrated:
            n_access = int(rng.integers(10, 25))
        else:
            n_access = int(rng.integers(6, 18))

        for _ in range(n_access):
            rows.append({
                "access_id": _stable_id(cfg.seed, "resource_access", idx),
                "student_id": student["student_id"],
                "material_id": str(rng.choice(program_materials)),
                "access_timestamp": end_dt - timedelta(days=int(rng.integers(0, history_days + 1)), minutes=int(rng.integers(0, 1440))),
                "duration_seconds": int(rng.integers(60, 5400 if not is_churned else 1800)),
            })
            idx += 1
    return pd.DataFrame(rows)

def _support_ticket_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame, run_date: date) -> pd.DataFrame:
    categories = ["technical", "academic", "billing", "counseling"]
    priorities = ["low", "medium", "high"]
    history_days = _history_days(cfg)
    rows: List[dict] = []
    idx = 0
    for _, student in df_student.iterrows():
        is_churned = student["status"] == "inactive"
        create_ticket = rng.random() < (0.28 if is_churned else 0.14)
        if not create_ticket:
            continue
        n_tickets = int(rng.integers(1, 4 if is_churned else 3))
        for _ in range(n_tickets):
            created = run_date - timedelta(days=int(rng.integers(1, history_days + 1)))
            status = str(rng.choice(["closed", "open", "in_progress"], p=[0.72, 0.12, 0.16]))
            resolved = created + timedelta(days=int(rng.integers(1, 15))) if status == "closed" else None
            rows.append({
                "ticket_id": _stable_id(cfg.seed, "support_ticket", idx),
                "student_id": student["student_id"],
                "category": str(rng.choice(categories)),
                "priority": str(rng.choice(priorities, p=[0.45, 0.40, 0.15])),
                "status": status,
                "created_at": created,
                "resolved_at": resolved,
            })
            idx += 1
    return pd.DataFrame(rows)

def _system_log_table(cfg: PipelineConfig, rng: np.random.Generator, df_student: pd.DataFrame) -> pd.DataFrame:
    events = ["login", "logout", "assignment start", "resource view", "assignment_submit", "resource download", "quiz_attempt"]
    _, end_date = _dataset_window(cfg)
    end_dt = datetime.combine(end_date, datetime.min.time()) + timedelta(hours=23, minutes=59)
    history_days = _history_days(cfg)
    rows: List[dict] = []
    idx = 0
    for _, student in df_student.iterrows():
        is_churned = student["status"] == "inactive"
        n_events = int(rng.integers(2, 8) if is_churned else rng.integers(6, 20))
        for _ in range(n_events):
            rows.append({
                "log_id": _stable_id(cfg.seed, "system_log", idx),
                "user_id": student["student_id"],
                "event_type": str(rng.choice(events)),
                "event_timestamp": end_dt - timedelta(days=int(rng.integers(0, history_days + 1)), minutes=int(rng.integers(0, 1440))),
            })
            idx += 1
    return pd.DataFrame(rows)

def retention_action_table(cfg: PipelineConfig, rng: np.random.Generator, df_churn_prediction: pd.DataFrame, run_date: date) -> pd.DataFrame:
    action_types = ["counseling_call", "extra_tutoring", "study_plan_reset", "fee_support"]
    outcomes = ["effective", "ineffective", "pending"]
    history_days = _history_days(cfg)
    action_window = max(90, min(history_days, 360))

    high_risk = df_churn_prediction[df_churn_prediction["risk_level"] == "high"].copy()
    medium_risk = df_churn_prediction[df_churn_prediction["risk_level"] == "medium"].copy()
    selected_high = high_risk.sample(frac=0.75, random_state=cfg.seed) if not high_risk.empty else high_risk
    selected_medium = medium_risk.sample(frac=0.25, random_state=cfg.seed) if not medium_risk.empty else medium_risk
    selected = pd.concat([selected_high, selected_medium], ignore_index=True)

    rows: List[dict] = []
    for idx, (_, row) in enumerate(selected.iterrows()):
        rows.append({
            "action_id": _stable_id(cfg.seed, "retention_action", idx),
            "student_id": row["student_id"],
            "prediction_id": row["prediction_id"],
            "risk_level": row["risk_level"],
            "action_type": str(rng.choice(action_types)),
            "action_date": run_date - timedelta(days=int(rng.integers(0, action_window + 1))),
            "outcome": str(rng.choice(outcomes, p=[0.42, 0.21, 0.37])),
            "notes": "Follow-up scheduled",
        })
    return pd.DataFrame(rows)

def _student_monthly_features_table(cfg: PipelineConfig, df_student: pd.DataFrame, df_session: pd.DataFrame, df_attendance: pd.DataFrame, df_submission: pd.DataFrame, df_assignment: pd.DataFrame, df_resource_access: pd.DataFrame, df_support_ticket: pd.DataFrame, df_payment_transactions: pd.DataFrame, df_student_metrics: pd.DataFrame) -> pd.DataFrame:
    """Build month-level behavioral features constrained by join date and lifecycle end."""
    _end_date = _dataset_window(cfg)[1]
    end_month_start = pd.Timestamp(_end_date).to_period("M").to_timestamp()
    snapshot_rows: List[dict] = []

    for _, student in df_student.iterrows():
        join_date = date(int(student["join_year"]), 6, 15)
        join_month_start = pd.Timestamp(join_date).to_period("M").to_timestamp()
        program_end_date = (pd.Timestamp(join_date) + pd.DateOffset(years=int(student["program_duration"]))) - pd.Timedelta(days=1)
        program_end_month_start = pd.Timestamp(program_end_date).to_period("M").to_timestamp()
        effective_end = min(end_month_start, program_end_month_start)

        if effective_end < join_month_start:
            continue

        month_starts = pd.date_range(start=join_month_start, end=effective_end, freq="MS")
        for month_start in month_starts:
            snapshot_rows.append({
                "student_id": student["student_id"],
                "month_start": month_start,
                "path": student["path"],
                "grade": int(student["grade"]),
                "program_year": int(student["program_year"]),
                "status": student["status"],
                "join_year": int(student["join_year"]),
                "program_duration": int(student["program_duration"]),
            })

    snapshots = pd.DataFrame(snapshot_rows)
    if snapshots.empty:
        return pd.DataFrame(columns=["monthly_feature_id", "student_id", "month_start", "path", "grade", "program_year", "monthly_attendance_rate", "monthly_engagement_avg", "sessions_count", "monthly_assignment_score_avg", "submissions_count", "submitted_points", "resource_access_count", "resource_duration_min", "support_ticket_count", "high_priority_ticket_count", "billed_amount", "paid_amount", "paid_ratio_month", "days_since_last_login", "status", "status_flag"])

    snapshots["month_end"] = snapshots["month_start"] + pd.offsets.MonthEnd(1)
    attendance = df_attendance.copy()
    if "session_date" not in attendance.columns:
        attendance = attendance.merge(df_session[["session_id", "session_date"]], on="session_id", how="left")
    attendance["month_start"] = pd.to_datetime(attendance["session_date"]).dt.to_period("M").dt.to_timestamp()
    att_month = attendance.groupby(["student_id", "month_start"], as_index=False).agg(monthly_attendance_rate=("attended", "mean"), monthly_engagement_avg=("engagement_score", "mean"), sessions_count=("session_id", "nunique"))

    submissions = df_submission.merge(df_assignment[["assignment_id", "due_date"]], on="assignment_id", how="left")
    submissions["month_start"] = pd.to_datetime(submissions["submission_date"]).dt.to_period("M").dt.to_timestamp()
    sub_month = submissions.groupby(["student_id", "month_start"], as_index=False).agg(monthly_assignment_score_avg=("score", "mean"), submissions_count=("submission_id", "nunique"), submitted_points=("score", "sum"))

    access = df_resource_access.copy()
    access["month_start"] = pd.to_datetime(access["access_timestamp"]).dt.to_period("M").dt.to_timestamp()
    access_month = access.groupby(["student_id", "month_start"], as_index=False).agg(resource_access_count=("access_id", "nunique"), resource_duration_min=("duration_seconds", lambda x: float(x.sum()) / 60.0))

    tickets = df_support_ticket.copy()
    tickets["month_start"] = pd.to_datetime(tickets["created_at"]).dt.to_period("M").dt.to_timestamp()
    ticket_month = tickets.groupby(["student_id", "month_start"], as_index=False).agg(support_ticket_count=("ticket_id", "nunique"), high_priority_ticket_count=("priority", lambda x: int((x == "high").sum())))

    payments = df_payment_transactions.copy()
    payments["month_start"] = pd.to_datetime(payments["payment_date"]).dt.to_period("M").dt.to_timestamp()
    payments["paid_component"] = np.where(payments["status"] == "paid", payments["amount"], 0)
    pay_month = payments.groupby(["student_id", "month_start"], as_index=False).agg(paid_amount=("paid_component", "sum"), billed_amount=("amount", "sum"))

    snapshots = snapshots.merge(att_month, on=["student_id", "month_start"], how="left")
    snapshots = snapshots.merge(sub_month, on=["student_id", "month_start"], how="left")
    snapshots = snapshots.merge(access_month, on=["student_id", "month_start"], how="left")
    snapshots = snapshots.merge(ticket_month, on=["student_id", "month_start"], how="left")
    snapshots = snapshots.merge(pay_month, on=["student_id", "month_start"], how="left")

    metrics = df_student_metrics[["student_id", "last_login_date"]].copy()
    metrics["last_login_date"] = pd.to_datetime(metrics["last_login_date"])
    snapshots = snapshots.merge(metrics, on="student_id", how="left")
    snapshots["days_since_last_login"] = (snapshots["month_end"] - snapshots["last_login_date"]).dt.days.clip(lower=0)

    numeric_cols = ["monthly_attendance_rate", "monthly_engagement_avg", "sessions_count", "monthly_assignment_score_avg", "submissions_count", "submitted_points", "resource_access_count", "resource_duration_min", "support_ticket_count", "high_priority_ticket_count", "billed_amount", "paid_amount", "days_since_last_login"]
    for col in numeric_cols:
        if col not in snapshots.columns:
            snapshots[col] = 0
    snapshots[numeric_cols] = snapshots[numeric_cols].fillna(0)

    snapshots["paid_ratio_month"] = np.where(snapshots["billed_amount"] > 0, snapshots["paid_amount"] / snapshots["billed_amount"], 0.0)
    snapshots["status_flag"] = (snapshots["status"] == "inactive").astype(int)
    snapshots = snapshots.sort_values(["student_id", "month_start"]).reset_index(drop=True)
    snapshots.insert(0, "monthly_feature_id", [_stable_id(cfg.seed, "monthly_features", i) for i in range(len(snapshots))])

    return snapshots[["monthly_feature_id", "student_id", "month_start", "path", "grade", "program_year", "monthly_attendance_rate", "monthly_engagement_avg", "sessions_count", "monthly_assignment_score_avg", "submissions_count", "submitted_points", "resource_access_count", "resource_duration_min", "support_ticket_count", "high_priority_ticket_count", "billed_amount", "paid_amount", "paid_ratio_month", "days_since_last_login", "status", "status_flag"]]

def _validation_report(cfg: PipelineConfig, tables: Dict[str, pd.DataFrame]) -> Dict[str, object]:
    """Run structural, business rule, and temporal integrity checks across all tables."""
    errors: List[str] = []

    def unique_check(table: str, col: str) -> None:
        dupes = int(tables[table][col].duplicated().sum())
        if dupes > 0:
            errors.append(f"{table}.{col} has {dupes} duplicate values")

    def fk_check(child: str, fk_col: str, parent: str, pk_col: str) -> None:
        mask = ~tables[child][fk_col].isin(tables[parent][pk_col])
        bad = int(mask.sum())
        if bad > 0:
            errors.append(f"{child}.{fk_col} has {bad} values missing in {parent}.{pk_col}")

    unique_check("01_program", "program_id")
    unique_check("02_faculty", "faculty_id")
    unique_check("03_cohort", "cohort_id")
    unique_check("04_student", "student_id")
    unique_check("05_session", "session_id")
    unique_check("06_attendance", "attendance_id")
    unique_check("07_assignment", "assignment_id")
    unique_check("08_submission", "submission_id")
    unique_check("09_student_metrics", "metric_id")
    unique_check("10_churn_prediction", "prediction_id")
    unique_check("11_feedback", "feedback_id")
    unique_check("12_payment_transactions", "payment_id")
    unique_check("13_student_finance", "finance_id")
    unique_check("14_material", "material_id")
    unique_check("15_resource_access", "access_id")
    unique_check("16_support_ticket", "ticket_id")
    unique_check("17_system_log", "log_id")
    unique_check("18_retention_action", "action_id")
    unique_check("19_student_monthly_features", "monthly_feature_id")

    fk_check("03_cohort", "program_id", "01_program", "program_id")
    fk_check("04_student", "cohort_id", "03_cohort", "cohort_id")
    fk_check("04_student", "program_id", "01_program", "program_id")
    fk_check("05_session", "cohort_id", "03_cohort", "cohort_id")
    fk_check("06_attendance", "student_id", "04_student", "student_id")
    fk_check("06_attendance", "session_id", "05_session", "session_id")
    fk_check("07_assignment", "cohort_id", "03_cohort", "cohort_id")
    fk_check("08_submission", "assignment_id", "07_assignment", "assignment_id")
    fk_check("08_submission", "student_id", "04_student", "student_id")
    fk_check("09_student_metrics", "student_id", "04_student", "student_id")
    fk_check("10_churn_prediction", "student_id", "04_student", "student_id")
    fk_check("11_feedback", "student_id", "04_student", "student_id")
    fk_check("14_material", "program_id", "01_program", "program_id")
    fk_check("15_resource_access", "student_id", "04_student", "student_id")
    fk_check("15_resource_access", "material_id", "14_material", "material_id")
    fk_check("16_support_ticket", "student_id", "04_student", "student_id")
    fk_check("17_system_log", "user_id", "04_student", "student_id")
    fk_check("18_retention_action", "student_id", "04_student", "student_id")
    fk_check("18_retention_action", "prediction_id", "10_churn_prediction", "prediction_id")
    fk_check("19_student_monthly_features", "student_id", "04_student", "student_id")

    if len(tables["04_student"]) <= 5000:
        errors.append("04_student must contain more than 5000 students")

    over_cap = tables["03_cohort"][tables["03_cohort"]["total_students"] > cfg.standalone_max_students]
    if not over_cap.empty:
        errors.append(f"03_cohort has {len(over_cap)} cohorts above cap {cfg.standalone_max_students}")

    integrated = tables["03_cohort"][tables["03_cohort"]["path"].str.startswith("INT")].copy()
    for path, group in integrated.groupby("path"):
        ordered = group.sort_values("program_year")
        diffs = ordered["total_students"].diff().fillna(0)
        if (diffs > 0).any():
            errors.append(f"03_cohort has increasing student count across years for integrated path {path}")

    email_has_cy = int(tables["04_student"]["email"].str.contains(r"\.cy\d+@", regex=True).sum())
    if email_has_cy > 0:
        errors.append(f"04_student has {email_has_cy} emails containing disallowed current-year suffix")

    submission_with_due = tables["08_submission"].merge(tables["07_assignment"][["assignment_id", "due_date"]], on="assignment_id", how="left")
    bad_submission_dates = int((submission_with_due["submission_date"] > submission_with_due["due_date"]).sum())
    if bad_submission_dates > 0:
        errors.append(f"08_submission has {bad_submission_dates} records where submission_date > due_date")

    _, end_date = _dataset_window(cfg)
    future_submissions = int((pd.to_datetime(tables["08_submission"]["submission_date"]).dt.date > end_date).sum())
    if future_submissions > 0:
        errors.append(f"08_submission has {future_submissions} records after dataset end date {end_date}")

    future_assignment_due = int((pd.to_datetime(tables["07_assignment"]["due_date"]).dt.date > end_date).sum())
    if future_assignment_due > 0:
        errors.append(f"07_assignment has {future_assignment_due} due dates after dataset end date {end_date}")

    session_dates = tables["05_session"].copy()
    session_dates["session_date"] = pd.to_datetime(session_dates["session_date"])
    future_sessions = int((session_dates["session_date"].dt.date > end_date).sum())
    if future_sessions > 0:
        errors.append(f"05_session has {future_sessions} session dates after dataset end date {end_date}")

    session_span = session_dates.groupby("cohort_id")["session_date"].agg(["min", "max"])
    min_expected_span = int(_history_days(cfg) * 0.8)
    short_span = int(((session_span["max"] - session_span["min"]).dt.days < min_expected_span).sum())
    if short_span > 0:
        errors.append(f"05_session has {short_span} cohorts with less than expected history span ({min_expected_span} days)")

    monthly = tables["19_student_monthly_features"].copy()
    monthly["month_start"] = pd.to_datetime(monthly["month_start"])
    monthly_span = monthly.groupby("student_id")["month_start"].agg(["min", "max", "nunique"]).reset_index()
    students = tables["04_student"][["student_id", "join_year", "program_duration"]].copy()
    students["join_month"] = pd.to_datetime(students["join_year"].astype(str) + "-06-01")
    students["program_end_month"] = students.apply(lambda r: (r["join_month"] + pd.DateOffset(years=int(r["program_duration"])) - pd.Timedelta(days=1)).to_period("M").to_timestamp(), axis=1)
    students["dataset_end_month"] = pd.Timestamp(end_date).to_period("M").to_timestamp()
    students["expected_last_month"] = students[["program_end_month", "dataset_end_month"]].min(axis=1)

    monthly_check = monthly_span.merge(students[["student_id", "join_month", "expected_last_month"]], on="student_id", how="left")
    bad_before_join = int((monthly_check["min"] < monthly_check["join_month"]).sum())
    if bad_before_join > 0:
        errors.append(f"19_student_monthly_features has {bad_before_join} students with months before join month")
    bad_after_end = int((monthly_check["max"] > monthly_check["expected_last_month"]).sum())
    if bad_after_end > 0:
        errors.append(f"19_student_monthly_features has {bad_after_end} students with months after allowed program/as-of end")

    finance = tables["13_student_finance"].copy()
    payments = tables["12_payment_transactions"].copy()
    if len(finance) < len(tables["04_student"]):
        errors.append("13_student_finance should include at least all student records")
    non_positive_actual = int((finance["actual_revenue"] <= 0).sum())
    if non_positive_actual > 0:
        errors.append(f"13_student_finance has {non_positive_actual} records with non-positive actual revenue")
    overpaid = int((finance["actual_revenue"] > finance["planned_revenue"]).sum())
    if overpaid > 0:
        errors.append(f"13_student_finance has {overpaid} records with actual_revenue > planned_revenue")
    bad_outstanding = int((finance["outstanding_amount"] != (finance["planned_revenue"] - finance["actual_revenue"]).astype(int)).sum())
    if bad_outstanding > 0:
        errors.append(f"13_student_finance has {bad_outstanding} rows with incorrect outstanding_amount")
    bad_cumulative = int((finance["planned_revenue"] != finance["fee_to_current_year"]).sum())
    if bad_cumulative > 0:
        errors.append(f"13_student_finance has {bad_cumulative} rows where planned_revenue is not cumulative")
    bad_duration = int((finance["program_year"] > finance["program_duration"]).sum())
    if bad_duration > 0:
        errors.append(f"13_student_finance has {bad_duration} rows with program_year > program_duration")
    bad_full_cap = int((finance["planned_revenue"] > finance["full_program_fee"]).sum())
    if bad_full_cap > 0:
        errors.append(f"13_student_finance has {bad_full_cap} rows above full_program_fee cap")

    sa_mask = finance["path"].str.startswith("SA")
    sa_bad_plan = int((finance.loc[sa_mask, "planned_revenue"] != finance.loc[sa_mask, "current_year_fee"]).sum())
    if sa_bad_plan > 0:
        errors.append(f"13_student_finance has {sa_bad_plan} stand-alone rows with invalid planned_revenue")

    paid = payments[payments["status"] == "paid"].groupby("student_id")["amount"].sum().rename("paid_amount")
    compare = finance.set_index("student_id").join(paid, how="left").fillna({"paid_amount": 0})
    future_payments = int((pd.to_datetime(payments["payment_date"]).dt.date > end_date).sum())
    if future_payments > 0:
        errors.append(f"12_payment_transactions has {future_payments} payment dates after dataset end date {end_date}")
    missing_paid = int((compare["paid_amount"] <= 0).sum())
    if missing_paid > 0:
        errors.append(f"13_student_finance has {missing_paid} students without any paid transaction")
    mismatches = int((compare["actual_revenue"] != compare["paid_amount"]).sum())
    if mismatches > 0:
        errors.append(f"13_student_finance actual revenue mismatches paid transactions for {mismatches} students")

    metrics_with_status = tables["09_student_metrics"].merge(tables["04_student"][["student_id", "status"]], on="student_id", how="left")
    active = metrics_with_status[metrics_with_status["status"] == "active"]
    inactive = metrics_with_status[metrics_with_status["status"] == "inactive"]
    if not inactive["attendance_percentage"].mean() < active["attendance_percentage"].mean():
        errors.append("Inactive students should have lower average attendance than active students")
    if not inactive["avg_assignment_score"].mean() < active["avg_assignment_score"].mean():
        errors.append("Inactive students should have lower average assignment score than active students")

    row_counts = {name: int(len(df)) for name, df in tables.items()}
    return {"ok": len(errors) == 0, "errors": errors, "row_counts": row_counts}

def _metadata_table(tables: Dict[str, pd.DataFrame]) -> pd.DataFrame:
    rows: List[dict] = []
    for table_name, df in tables.items():
        for col in df.columns:
            rows.append({"table_name": table_name, "column_name": col, "data_type": str(df[col].dtype), "null_count": int(df[col].isna().sum()), "row_count": int(len(df))})
    return pd.DataFrame(rows)

def _export(cfg: PipelineConfig, tables: Dict[str, pd.DataFrame], report: Dict[str, object]) -> None:
    """Persist generated outputs as per-table CSVs, workbook, and run summary JSON."""
    root = Path(cfg.output_dir)
    csv_dir = root / "csv"
    root.mkdir(parents=True, exist_ok=True)
    csv_dir.mkdir(parents=True, exist_ok=True)
    for table_name, df in tables.items():
        df.to_csv(csv_dir / f"{table_name}.csv", index=False)

    metadata = _metadata_table(tables)
    excel_path = root / cfg.excel_filename
    with pd.ExcelWriter(excel_path, engine="openpyxl") as writer:
        metadata.to_excel(writer, sheet_name="00_Metadata_Dictionary", index=False)
        for table_name, df in tables.items():
            df.to_excel(writer, sheet_name=table_name[:31], index=False)

    summary = {"generated_at": datetime.now().isoformat(timespec="seconds"), "config": asdict(cfg), "validation": report, "excel_output": str(excel_path), "csv_output_dir": str(csv_dir)}
    with open(root / "run_summary.json", "w", encoding="utf-8") as f:
        json.dump(summary, f, indent=2, default=str)

def run_pipeline(cfg: PipelineConfig) -> Tuple[Dict[str, pd.DataFrame], Dict[str, object]]:
    """Generate, validate, and export the full canonical EdTech dataset."""
    rng = np.random.default_rng(cfg.seed)
    run_date = _dataset_window(cfg)[1]

    # Core entities.
    df_program = _program_table(cfg, run_date)
    df_faculty = _faculty_table(cfg, rng, run_date)
    df_cohort = cohort_table(cfg, rng, df_program)
    df_student = student_table(cfg, rng, df_cohort)
    df_session = _session_table(cfg, rng, df_cohort)

    # Academic activity.
    df_attendance = _attendance_table(cfg, rng, df_student, df_session, run_date)
    df_assignment = _assignment_table(cfg, df_cohort, run_date)
    df_submission = _submission_table(cfg, rng, df_student, df_assignment, run_date)

    # Student outcomes and risk signals.
    df_student_metrics = _student_metrics_table(cfg, rng, df_student, df_attendance, df_submission, run_date)
    df_churn_prediction = churn_prediction_table(cfg, df_student_metrics, run_date)
    df_feedback = feedback_table(cfg, rng, df_student, run_date)

    # Financials.
    df_payments, df_finance = payment_and_finance_tables(cfg, rng, df_student, df_program, run_date)

    # Learning resources and support operations.
    df_material = _material_table(cfg, rng, df_program, run_date)
    df_resource_access = resource_access_table(cfg, rng, df_student, df_material)
    df_support_ticket = _support_ticket_table(cfg, rng, df_student, run_date)
    df_system_log = _system_log_table(cfg, rng, df_student)
    df_retention_action = retention_action_table(cfg, rng, df_churn_prediction, run_date)

    # Monthly feature store for unsupervised modeling and segmentation.
    df_monthly_features = _student_monthly_features_table(cfg, df_student, df_session, df_attendance, df_submission, df_assignment, df_resource_access, df_support_ticket, df_payments, df_student_metrics)

    tables = {
        "01_program": df_program, "02_faculty": df_faculty, "03_cohort": df_cohort, "04_student": df_student,
        "05_session": df_session, "06_attendance": df_attendance, "07_assignment": df_assignment, "08_submission": df_submission,
        "09_student_metrics": df_student_metrics, "10_churn_prediction": df_churn_prediction, "11_feedback": df_feedback,
        "12_payment_transactions": df_payments, "13_student_finance": df_finance, "14_material": df_material,
        "15_resource_access": df_resource_access, "16_support_ticket": df_support_ticket, "17_system_log": df_system_log,
        "18_retention_action": df_retention_action, "19_student_monthly_features": df_monthly_features,
    }

    report = _validation_report(cfg, tables)
    if not report["ok"]:
        details = "\n" + "\n".join(report["errors"]) if report["errors"] else ""
        raise ValueError(f"Data validation failed: {details}")

    _export(cfg, tables, report)
    return tables, report

def parse_args() -> argparse.Namespace:
    """Parse CLI overrides for reproducible, editor-agnostic runs."""
    parser = argparse.ArgumentParser(description="Generate canonical IIMA EdTech synthetic dataset")
    parser.add_argument("--output-dir", default=PipelineConfig.output_dir)
    parser.add_argument("--excel-filename", default=PipelineConfig.excel_filename)
    parser.add_argument("--seed", type=int, default=PipelineConfig.seed)
    parser.add_argument("--num-students-target", type=int, default=PipelineConfig.num_students_target)
    parser.add_argument("--num-teachers", type=int, default=PipelineConfig.num_teachers)
    parser.add_argument("--num-faculty", type=int, dest="num_teachers", help=argparse.SUPPRESS)
    parser.add_argument("--churn-ratio", type=float, default=PipelineConfig.churn_ratio)
    parser.add_argument("--enrollment-year", type=int, default=PipelineConfig.enrollment_year)
    parser.add_argument("--standalone-max-students", type=int, default=PipelineConfig.standalone_max_students)
    parser.add_argument("--history-months", type=int, default=PipelineConfig.history_months)
    parser.add_argument("--session-weeks", type=int, default=PipelineConfig.session_weeks)
    parser.add_argument("--assignment-count", type=int, default=PipelineConfig.assignment_count)
    parser.add_argument("--legacy-finance-ratio", type=float, default=PipelineConfig.legacy_finance_ratio)
    parser.add_argument("--min-legacy-finance-students", type=int, default=PipelineConfig.min_legacy_finance_students)
    parser.add_argument("--as-of-date", default=PipelineConfig.as_of_date)

    args, unknown = parser.parse_known_args()
    if unknown:
        launcher = Path(sys.argv[0]).name.lower()
        # FIX: Added "colab" to the list of recognized notebook runtimes
        is_notebook_runtime = ("ipykernel" in launcher) or ("jupyter" in launcher) or ("colab" in launcher)
        is_kernel_file_arg = len(unknown) == 2 and unknown[0] == "-f" and unknown[1].endswith(".json")
        
        if not (is_notebook_runtime and is_kernel_file_arg):
            parser.error(f"unrecognized arguments: {' '.join(unknown)}")
            
    return args

def main() -> None:
    """CLI entrypoint for generating and exporting the complete dataset."""
    args = parse_args()
    cfg = PipelineConfig(
        output_dir=args.output_dir, excel_filename=args.excel_filename, seed=args.seed,
        enrollment_year=args.enrollment_year, num_students_target=args.num_students_target,
        num_teachers=args.num_teachers, churn_ratio=args.churn_ratio,
        standalone_max_students=args.standalone_max_students, history_months=args.history_months,
        session_weeks=args.session_weeks, assignment_count=args.assignment_count,
        legacy_finance_ratio=args.legacy_finance_ratio, min_legacy_finance_students=args.min_legacy_finance_students,
        as_of_date=args.as_of_date,
    )

    _, report = run_pipeline(cfg)
    print("Pipeline completed successfully")
    print(f"Output directory: {cfg.output_dir}")
    print("Row counts:")
    for name, count in report["row_counts"].items():
        print(f"  {name}: {count}")

if __name__ == "__main__":
    main()
